# Альтернативно можно добавить в reset_stale_tasks:

def reset_stale_tasks(self, workspace_dir: Path = None) -> int:
    """Reset in_progress -> pending at startup. Returns count."""
    count = 0
    for task in self.tasks:
        if task.status == "in_progress":
            task.status = "pending"
            count += 1

    # 🔧 НОВОЕ: Recovery done статусов
    if workspace_dir:
        from whilly.recovery import recover_task_statuses
        recovered = recover_task_statuses(self, workspace_dir)
        if recovered:
            count += len(recovered)

    if count:
        self.save()
    return count