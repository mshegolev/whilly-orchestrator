<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <title>Check your inbox — Whilly</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/static/whilly-design.css">
  <link rel="stylesheet" href="/static/whilly-app.css">
  <style>
    body { min-height: 100vh; display: grid; place-items: center; }
    .login-wrap { width: min(500px, calc(100vw - 32px)); }
    .login-frame {
      border: 1px solid var(--line-strong);
      background: var(--surface);
      padding: 0;
    }
    .login-titlebar {
      display: flex; align-items: center; gap: 0;
      border-bottom: 1px solid var(--line-strong);
      padding: 6px 10px;
      background: var(--surface-strong);
      font: 700 var(--t-body)/var(--lh-tight) var(--font-mono);
      color: var(--text);
    }
    .login-titlebar .corner { color: var(--muted); }
    .login-titlebar .title { flex: 1; color: var(--ok); margin: 0; font: inherit; }
    .login-body { padding: 20px; font: var(--t-body)/var(--lh-body) var(--font-mono); }
    .login-body p { margin: 0 0 12px; color: var(--text); }
    .email-tag {
      display: inline;
      padding: 1px 6px;
      background: var(--surface-strong);
      border: 1px solid var(--line-strong);
      color: var(--accent);
      font: var(--t-body)/var(--lh-body) var(--font-mono);
    }
    .dev-note {
      margin-top: 16px;
      padding: 8px 10px;
      border: 1px solid var(--warn);
      color: var(--warn);
      font: var(--t-sm)/var(--lh-body) var(--font-mono);
    }
    .dev-note strong { font-weight: 700; }
    .login-alt {
      margin-top: 16px;
      padding-top: 12px;
      border-top: 1px solid var(--line);
      font: var(--t-sm)/var(--lh-body) var(--font-mono);
      color: var(--muted);
    }
    .login-alt a { color: var(--accent); text-decoration: none; }
    .login-alt a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="login-wrap">
    <div class="login-frame">
      <div class="login-titlebar">
        <span class="corner">&#9581;&#9472; </span>
        <h1 class="title">Check your inbox</h1>
        <span class="corner"> &#9472;&#9585;</span>
      </div>
      <div class="login-body">
        <p>
          sign-in link sent to <span class="email-tag">{{ email }}</span>.
          click it to finish signing in. valid for 15 minutes.
        </p>

        {# Dev-mode note — never renders the link itself. Operators retrieve the
           link from whilly_events.jsonl. Frontend F7 + Devil's Advocate #2. #}
        <div class="dev-note" role="note">
          <strong>[dev]</strong> link written to <code>whilly_logs/whilly_events.jsonl</code>
          (event type <code>auth.magic_link.issued</code>). tail the file to copy the URL.
        </div>

        <div class="login-alt">
          wrong address? <a href="/login?email={{ email | urlencode }}">Send again</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
