<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Sign in — Whilly</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    :root { color-scheme: light dark; }
    body {
      font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      max-width: 28rem; margin: 6rem auto; padding: 0 1.5rem;
      line-height: 1.5;
    }
    h1 { font-size: 1.4rem; margin-bottom: 0.5rem; }
    p.muted { color: #6b7280; margin-top: 0; }
    form { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
    label { font-size: 0.85rem; font-weight: 600; }
    input[type="text"], input[type="email"], input[type="password"] {
      padding: 0.6rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.375rem;
      font-size: 1rem;
    }
    input[type="text"]:focus, input[type="email"]:focus, input[type="password"]:focus {
      outline: 2px solid #2563eb; outline-offset: 1px;
    }
    button[type="submit"] {
      padding: 0.6rem 1rem; background: #2563eb; color: white; border: none;
      border-radius: 0.375rem; font-size: 1rem; font-weight: 600; cursor: pointer;
    }
    button[type="submit"]:hover { background: #1d4ed8; }
    .error {
      margin-top: 1rem; padding: 0.6rem 0.75rem; background: #fee2e2;
      border-left: 3px solid #dc2626; border-radius: 0.25rem;
      color: #7f1d1d; font-size: 0.9rem;
    }
    .alt-method {
      margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #e5e7eb;
      font-size: 0.85rem; color: #6b7280;
    }
    .alt-method a { color: #2563eb; }
  </style>
</head>
<body>
  <h1>Sign in to Whilly</h1>
  <p class="muted">Default credentials: <code>admin</code> / <code>admin</code> (change after first login).</p>

  {% if login_error %}
    <div class="error" role="alert">{{ login_error }}</div>
  {% endif %}

  <form method="post" action="/auth/login" novalidate>
    <label for="username">Username</label>
    <input
      id="username"
      name="username"
      type="text"
      autocomplete="username"
      required
      autofocus
      value="{{ username_prefill | default('') }}"
      placeholder="admin"
    />

    <label for="password">Password</label>
    <input
      id="password"
      name="password"
      type="password"
      autocomplete="current-password"
      required
      placeholder="••••••"
    />

    <button type="submit">Sign in</button>
  </form>

  <div class="alt-method">
    Need a magic link instead?
    <a href="/login/magic{% if username_prefill %}?email={{ username_prefill | urlencode }}{% endif %}">Sign in by email</a>
  </div>
</body>
</html>
