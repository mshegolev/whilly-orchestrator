<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Sign in — Whilly</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    :root { color-scheme: light dark; }
    body {
      font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      max-width: 28rem; margin: 6rem auto; padding: 0 1.5rem;
      line-height: 1.5;
    }
    h1 { font-size: 1.4rem; margin-bottom: 0.5rem; }
    p.muted { color: #6b7280; margin-top: 0; }
    form { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
    label { font-size: 0.85rem; font-weight: 600; }
    input[type="email"] {
      padding: 0.6rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.375rem;
      font-size: 1rem;
    }
    input[type="email"]:focus { outline: 2px solid #2563eb; outline-offset: 1px; }
    button[type="submit"] {
      padding: 0.6rem 1rem; background: #2563eb; color: white; border: none;
      border-radius: 0.375rem; font-size: 1rem; font-weight: 600; cursor: pointer;
    }
    button[type="submit"]:hover { background: #1d4ed8; }
  </style>
</head>
<body>
  <h1>Sign in to Whilly</h1>
  <p class="muted">Enter your email — we'll send a one-time link. No password required.</p>

  <form method="post" action="/auth/login" novalidate data-testid="login-form">
    <label for="email">Email</label>
    <input
      id="email"
      name="email"
      type="email"
      autocomplete="email"
      required
      autofocus
      value="{{ email_prefill | default('') }}"
      placeholder="you@example.com"
      data-testid="login-email-input"
    />
    <button type="submit" data-testid="login-submit-btn">Send sign-in link</button>
  </form>
</body>
</html>
