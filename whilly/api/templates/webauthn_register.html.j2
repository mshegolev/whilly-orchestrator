<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <title>Register a passkey — Whilly</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/static/whilly-design.css">
  <link rel="stylesheet" href="/static/whilly-app.css">
  <style>
    body { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
    .wa-wrap { width: min(460px, calc(100vw - 32px)); border: 1px solid var(--line-strong); padding: 20px; background: var(--surface); }
    .wa-title { color: var(--accent); margin: 0 0 12px; font: 700 var(--t-body)/var(--lh-tight) var(--font-mono); }
    .wa-hint { color: var(--muted); font: var(--t-sm)/var(--lh-body) var(--font-mono); margin-bottom: 16px; }
    .wa-btn { width: 100%; padding: 8px; background: transparent; color: var(--accent); border: 1px solid var(--accent); font: 700 var(--t-body)/var(--lh-body) var(--font-mono); cursor: pointer; }
    .wa-error { padding: 8px 12px; margin-bottom: 12px; border: 1px solid var(--danger); color: var(--danger); font: var(--t-sm)/var(--lh-body) var(--font-mono); }
    .wa-ok { padding: 8px 12px; margin-bottom: 12px; border: 1px solid var(--accent); color: var(--accent); font: var(--t-sm)/var(--lh-body) var(--font-mono); }
    .wa-alt { margin-top: 12px; text-align: center; color: var(--muted); font: var(--t-sm)/var(--lh-body) var(--font-mono); }
    .wa-alt a { color: var(--accent); text-decoration: none; }
  </style>
</head>
<body>
  <div class="wa-wrap">
    <h1 class="wa-title">Register a passkey</h1>
    <p class="wa-hint">
      Signed in as <strong>{{ username }}</strong>. You currently have
      <strong>{{ credential_count }}</strong> passkey(s) enrolled. Registering binds a
      new hardware key, phone, or platform authenticator to your admin account as a
      second factor.
    </p>
    <div id="wa-error" class="wa-error" role="alert" hidden></div>
    <div id="wa-ok" class="wa-ok" role="status" hidden></div>
    <button id="wa-go" class="wa-btn" type="button">[ register passkey ]</button>
    <p class="wa-alt"><a href="/me/sessions">back to my sessions</a></p>
  </div>
  <script>
    function b64urlToBuf(s) {
      s = s.replace(/-/g, "+").replace(/_/g, "/");
      const pad = s.length % 4 ? "=".repeat(4 - (s.length % 4)) : "";
      const bin = atob(s + pad);
      const buf = new Uint8Array(bin.length);
      for (let i = 0; i < bin.length; i++) buf[i] = bin.charCodeAt(i);
      return buf.buffer;
    }
    function bufToB64url(buf) {
      const bytes = new Uint8Array(buf);
      let bin = "";
      for (const b of bytes) bin += String.fromCharCode(b);
      return btoa(bin).replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/, "");
    }
    function showError(msg) {
      const el = document.getElementById("wa-error");
      el.textContent = msg; el.hidden = false;
      document.getElementById("wa-ok").hidden = true;
    }
    function showOk(msg) {
      const el = document.getElementById("wa-ok");
      el.textContent = msg; el.hidden = false;
      document.getElementById("wa-error").hidden = true;
    }
    async function register() {
      document.getElementById("wa-error").hidden = true;
      let options;
      try {
        const beginResp = await fetch("/me/webauthn/register/begin", { method: "POST" });
        if (!beginResp.ok) { showError("Could not start registration."); return; }
        options = await beginResp.json();
      } catch (e) { showError("Network error starting registration."); return; }
      options.challenge = b64urlToBuf(options.challenge);
      options.user.id = b64urlToBuf(options.user.id);
      (options.excludeCredentials || []).forEach((c) => { c.id = b64urlToBuf(c.id); });
      let cred;
      try {
        cred = await navigator.credentials.create({ publicKey: options });
      } catch (e) { showError("Passkey creation was cancelled or failed."); return; }
      const payload = {
        id: cred.id,
        rawId: bufToB64url(cred.rawId),
        type: cred.type,
        response: {
          clientDataJSON: bufToB64url(cred.response.clientDataJSON),
          attestationObject: bufToB64url(cred.response.attestationObject),
          transports: cred.response.getTransports ? cred.response.getTransports() : [],
        },
        clientExtensionResults: cred.getClientExtensionResults(),
      };
      let result;
      try {
        const finishResp = await fetch("/me/webauthn/register/finish", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        result = await finishResp.json();
      } catch (e) { showError("Network error finishing registration."); return; }
      if (result.verified) { showOk("Passkey registered. You can use it the next time you sign in."); }
      else { showError(result.error || "Registration failed."); }
    }
    document.getElementById("wa-go").addEventListener("click", register);
    if (!window.PublicKeyCredential) {
      showError("This browser does not support passkeys.");
      document.getElementById("wa-go").disabled = true;
    }
  </script>
</body>
</html>
