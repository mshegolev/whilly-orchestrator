<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="stylesheet" href="/static/whilly-design.css">
  <link rel="stylesheet" href="/static/whilly-app.css">
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% if events_token %}<meta name="whilly-events-token" content="{{ events_token }}">{% endif %}
  {# P1.5: kept for one-release backward compat; new auth path uses session cookie (withCredentials). #}
  <title>Whilly Control Plane</title>
  <script src="https://unpkg.com/htmx.org@1.9.12"
          crossorigin="anonymous"
          defer></script>
  <script src="https://unpkg.com/htmx-ext-sse@2.2.4/sse.js"
          crossorigin="anonymous"
          defer></script>
  <style>
    /* ── TUI override: force pure dark palette regardless of OS setting ── */
    :root {
      --bg:             #111315;
      --surface:        #171a1d;
      --surface-strong: #202428;
      --text:           #eceff3;
      --muted:          #a6adb7;
      --line:           #343a40;
      --line-strong:    #59616b;
      --accent:         #0f766e;
      --danger:         #b42318;
      --warn:           #a15c07;
      --ok:             #16703c;
      --info:           #0969da;
      --whilly-mono:    var(--font-mono);
      color-scheme:     dark;
    }
    * { box-sizing: border-box; }
    body.operator-console {
      margin: 0;
      color: var(--text);
      background: var(--bg);
      font-family: var(--whilly-mono);
      font-size: 13px;
      line-height: 1.45;
      overflow-x: hidden;
    }
    /* ── Auth nav bar ─────────────────────────────────────────────── */
    .wui-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 5px 10px;
      border-bottom: 1px solid var(--line-strong);
      background: var(--surface-strong);
      font: 400 12px/1.4 var(--whilly-mono);
      color: var(--muted);
      gap: 12px;
    }
    .wui-nav__identity strong { color: var(--text); }
    .wui-nav__identity::before { content: "&#9474; "; color: var(--line-strong); }
    .wui-nav__logout { margin: 0; display: flex; align-items: center; }
    .wui-nav__logout button {
      padding: 2px 10px;
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--line-strong);
      border-radius: 0;
      font: inherit;
      cursor: pointer;
      letter-spacing: 0.02em;
    }
    .wui-nav__logout button:hover, .wui-nav__logout button:focus-visible {
      color: var(--surface);
      background: var(--text);
      outline: none;
    }
    /* ── Plans section ────────────────────────────────────────────── */
    .wui-plans {
      border-bottom: 1px solid var(--line-strong);
      padding: 10px;
      background: var(--bg);
    }
    .wui-plans__head {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }
    .wui-plans__head h2 {
      font: 700 13px/1.2 var(--whilly-mono);
      color: var(--accent);
      margin: 0;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .wui-plans__head h2::before { content: "[ "; color: var(--muted); }
    .wui-plans__head h2::after  { content: " ]"; color: var(--muted); }
    .wui-plans__controls {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
      flex: 1;
    }
    .wui-plans__page-size-label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font: 12px/1.4 var(--whilly-mono);
      color: var(--muted);
    }
    .wui-plans__page-size-text { color: var(--muted); }
    .wui-plans__page-size-label select {
      background: var(--bg);
      color: var(--text);
      border: 1px solid var(--line-strong);
      border-radius: 0;
      padding: 2px 6px;
      font: 12px/1.4 var(--whilly-mono);
    }
    .wui-plans__page-size-label select:focus {
      outline: none;
      box-shadow: 0 0 0 2px var(--accent);
    }
    .wui-plans__pagination {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 10px;
      padding: 6px 4px;
      font: 12px/1.4 var(--whilly-mono);
      color: var(--muted);
      border-top: 1px solid var(--line);
    }
    .wui-plans__pagination-info { color: var(--muted); }
    .wui-plans__pagination-btn {
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--accent);
      border-radius: 0;
      padding: 2px 10px;
      font: 700 12px/1.4 var(--whilly-mono);
      cursor: pointer;
    }
    .wui-plans__pagination-btn:hover:not(:disabled),
    .wui-plans__pagination-btn:focus-visible {
      background: var(--accent);
      color: var(--bg);
      outline: none;
    }
    .wui-plans__pagination-btn:disabled {
      color: var(--muted);
      border-color: var(--line);
      cursor: not-allowed;
    }
    /* Generic pagination controls for tasks/workers tables — uses the
       same TUI style as wui-plans__pagination but sits above the table. */
    .wui-pagination-controls {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 10px;
      padding: 4px 0;
      font: 12px/1.4 var(--whilly-mono);
      color: var(--muted);
    }
    .wui-pagination-controls[hidden] { display: none; }
    .wui-plans__new-btn {
      padding: 3px 10px;
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--accent);
      border-radius: 0;
      font: 700 12px/1.4 var(--whilly-mono);
      cursor: pointer;
      white-space: nowrap;
    }
    .wui-plans__new-btn:hover, .wui-plans__new-btn:focus-visible {
      background: var(--accent);
      color: var(--bg);
      outline: none;
    }
    #plans-filter {
      min-height: 26px;
      padding: 3px 8px;
      background: var(--surface);
      color: var(--text);
      border: 1px solid var(--line-strong);
      border-radius: 0;
      font: 13px/1.4 var(--whilly-mono);
      flex: 1 1 200px;
      min-width: 140px;
    }
    #plans-filter::placeholder { color: var(--muted); }
    #plans-filter:focus { outline: none; box-shadow: 0 0 0 2px var(--accent); }
    .wui-plans__controls label {
      font: 12px/1.4 var(--whilly-mono);
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 5px;
      cursor: pointer;
      white-space: nowrap;
    }
    .wui-plans__controls label input[type="checkbox"] { accent-color: var(--accent); }
    .wui-plans__archived-count {
      font: 11px/1.4 var(--whilly-mono);
      color: var(--muted);
    }
    .wui-plans__empty-state {
      color: var(--muted);
      font: 12px/1.4 var(--whilly-mono);
      margin: 6px 0 0;
    }
    .wui-plans__empty-state button {
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--accent);
      border-radius: 0;
      padding: 2px 8px;
      font: inherit;
      cursor: pointer;
    }
    .wui-plans__empty-state button:hover { background: var(--accent); color: var(--bg); }
    .wui-plans table { border: 1px solid var(--line-strong); background: var(--surface); }
    .wui-plans th { background: var(--surface-strong); color: var(--muted); font: 700 11px/1.2 var(--whilly-mono); text-transform: uppercase; letter-spacing: .04em; border-bottom: 1px solid var(--line-strong); padding: 5px 8px; }
    .wui-plans td { padding: 5px 8px; border-bottom: 1px solid var(--line); color: var(--text); font: 13px/1.45 var(--whilly-mono); white-space: nowrap; }
    .wui-plans tbody tr:hover td { background: var(--surface-strong); cursor: pointer; }
    .wui-plans__empty td { color: var(--muted); font-style: italic; }
    .wui-plans__actions { position: relative; }
    .wui-plans__menu { position: relative; display: inline-block; }
    .wui-plans__menu summary {
      list-style: none;
      padding: 2px 8px;
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--line);
      border-radius: 0;
      font: 13px/1.4 var(--whilly-mono);
      cursor: pointer;
    }
    .wui-plans__menu summary:hover { background: var(--surface-strong); color: var(--text); }
    .wui-plans__menu[open] summary { color: var(--text); background: var(--surface-strong); }
    .wui-plans__menu-body {
      position: absolute;
      right: 0;
      top: 100%;
      z-index: 20;
      background: var(--surface);
      border: 1px solid var(--line-strong);
      min-width: 120px;
      display: flex;
      flex-direction: column;
    }
    .wui-plans__menu-body button {
      display: block;
      width: 100%;
      text-align: left;
      padding: 5px 10px;
      background: transparent;
      color: var(--text);
      border: 0;
      border-bottom: 1px solid var(--line);
      font: 12px/1.4 var(--whilly-mono);
      cursor: pointer;
    }
    .wui-plans__menu-body button:last-child { border-bottom: 0; }
    .wui-plans__menu-body button:hover { background: var(--surface-strong); color: var(--accent); }
    /* ── Dialog / modal TUI style ─────────────────────────────────── */
    dialog {
      position: fixed;
      inset: 0;
      margin: auto;
      padding: 0;
      background: var(--surface);
      color: var(--text);
      border: 1px solid var(--line-strong);
      border-radius: 0;
      width: min(480px, calc(100vw - 40px));
      max-height: calc(100vh - 80px);
      overflow-y: auto;
      font: 13px/1.45 var(--whilly-mono);
      box-shadow: none;
    }
    dialog::backdrop { background: rgba(0,0,0,0.7); }
    dialog h3 {
      margin: 0;
      padding: 7px 12px;
      font: 700 13px/1.2 var(--whilly-mono);
      color: var(--accent);
      background: var(--surface-strong);
      border-bottom: 1px solid var(--line-strong);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    dialog form { padding: 16px 14px 12px; display: flex; flex-direction: column; gap: 10px; }
    .wui-form-row { display: flex; flex-direction: column; gap: 4px; }
    .wui-form-row label {
      font: 700 11px/1.2 var(--whilly-mono);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--muted);
    }
    .wui-form-row label::before { content: "\25B8 "; color: var(--accent); }
    .wui-form-row label small { font-weight: 400; text-transform: none; letter-spacing: 0; color: var(--muted); opacity: 0.8; }
    .wui-form-row input[type="text"],
    .wui-form-row input[type="number"],
    .wui-form-row input[type="email"],
    .wui-form-row input[type="password"],
    .wui-form-row textarea,
    .wui-form-row select {
      padding: 4px 8px;
      background: var(--bg);
      color: var(--text);
      border: 1px solid var(--line-strong);
      border-radius: 0;
      font: 13px/1.45 var(--whilly-mono);
    }
    .wui-form-row input:focus,
    .wui-form-row textarea:focus,
    .wui-form-row select:focus { outline: none; box-shadow: 0 0 0 2px var(--accent); }
    .wui-form-row small#plan_id-help { color: var(--muted); font: 11px/1.3 var(--whilly-mono); }
    .wui-required { color: var(--danger); }
    .wui-error { color: var(--danger); font: 11px/1.3 var(--whilly-mono); }
    .wui-error[hidden] { display: none; }
    .wui-form-actions {
      display: flex;
      justify-content: flex-end;
      gap: 8px;
      margin-top: 4px;
      padding-top: 10px;
      border-top: 1px solid var(--line);
    }
    .wui-form-actions button {
      padding: 4px 16px;
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--accent);
      border-radius: 0;
      font: 700 12px/1.4 var(--whilly-mono);
      cursor: pointer;
    }
    .wui-form-actions button:hover, .wui-form-actions button:focus-visible {
      background: var(--accent);
      color: var(--bg);
      outline: none;
    }
    .wui-form-actions button[id$="cancel"],
    .wui-form-actions button.wui-btn--secondary {
      color: var(--muted);
      border-color: var(--line-strong);
    }
    .wui-form-actions button[id$="cancel"]:hover,
    .wui-form-actions button.wui-btn--secondary:hover {
      background: var(--surface-strong);
      color: var(--text);
    }
    .wui-btn--danger {
      color: var(--danger) !important;
      border-color: var(--danger) !important;
    }
    .wui-btn--danger:hover {
      background: var(--danger) !important;
      color: var(--bg) !important;
    }
    .wui-banner {
      padding: 8px 10px;
      border: 1px solid var(--line-strong);
      font: 12px/1.4 var(--whilly-mono);
      color: var(--text);
    }
    .wui-banner[hidden] { display: none; }
    .wui-banner--danger {
      border-color: var(--danger);
      color: var(--danger);
    }
    .wui-inline-confirm {
      font: 12px/1.4 var(--whilly-mono);
      color: var(--text);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      flex-wrap: wrap;
    }
    .task-edit-btn, .task-delete-btn {
      padding: 2px 8px;
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--line);
      border-radius: 0;
      font: 12px/1.4 var(--whilly-mono);
      cursor: pointer;
    }
    .task-edit-btn:hover { color: var(--accent); border-color: var(--accent); }
    .task-delete-btn:hover { color: var(--danger); border-color: var(--danger); }
    .tasks-actions { white-space: nowrap; }
    /* ── Jira import + Create Task panels ─────────────────────────── */
    .tui-panel-details {
      margin-bottom: 10px;
      border: 1px solid var(--line-strong);
      background: var(--surface);
    }
    .tui-panel-details summary {
      padding: 6px 10px;
      background: var(--surface-strong);
      border-bottom: 1px solid var(--line);
      font: 700 12px/1.4 var(--whilly-mono);
      color: var(--text);
      cursor: pointer;
      list-style: none;
      letter-spacing: 0.03em;
    }
    .tui-panel-details summary:hover { background: var(--surface-strong); color: var(--accent); }
    .tui-panel-details[open] summary { border-bottom: 1px solid var(--line-strong); color: var(--accent); }
    .tui-panel-details > summary::marker,
    .tui-panel-details > summary::-webkit-details-marker { display: none; }
    .tui-panel-details[open] > summary::before { content: "\25BC "; }
    .tui-panel-details > summary::before { content: "\25B6 "; color: var(--accent); }
    .tui-panel-body { padding: 12px 14px; }
    .tui-form-grid {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 8px 14px;
      align-items: start;
    }
    .tui-form-label {
      font: 700 11px/1.4 var(--whilly-mono);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--muted);
      padding-top: 5px;
    }
    .tui-form-label::before { content: "\25B8 "; color: var(--accent); }
    .tui-inp {
      width: 100%;
      padding: 4px 8px;
      background: var(--bg);
      color: var(--text);
      border: 1px solid var(--line-strong);
      border-radius: 0;
      font: 13px/1.45 var(--whilly-mono);
    }
    .tui-inp:focus { outline: none; box-shadow: 0 0 0 2px var(--accent); }
    .tui-inp::placeholder { color: var(--muted); }
    select.tui-inp { cursor: pointer; }
    textarea.tui-inp { resize: vertical; }
    .tui-check-row {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-top: 6px;
      font: 12px/1.4 var(--whilly-mono);
      color: var(--muted);
      cursor: pointer;
    }
    .tui-check-row input[type="checkbox"] { accent-color: var(--accent); }
    .tui-btn-row { margin-top: 12px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .tui-btn {
      padding: 4px 16px;
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--accent);
      border-radius: 0;
      font: 700 12px/1.4 var(--whilly-mono);
      cursor: pointer;
      white-space: nowrap;
    }
    .tui-btn:hover, .tui-btn:focus-visible { background: var(--accent); color: var(--bg); outline: none; }
    .tui-btn-secondary {
      color: var(--muted);
      border-color: var(--line-strong);
    }
    .tui-btn-secondary:hover { background: var(--surface-strong); color: var(--text); }
    .tui-status { font: 12px/1.4 var(--whilly-mono); color: var(--muted); }
    .tui-wizard-panel {
      margin-top: 14px;
      padding: 12px;
      border: 1px solid var(--line-strong);
      background: var(--surface-strong);
    }
    .tui-wizard-panel h3 {
      margin: 0 0 4px;
      font: 700 12px/1.2 var(--whilly-mono);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .tui-wizard-panel p { margin: 0 0 10px; font: 12px/1.4 var(--whilly-mono); color: var(--muted); }
    /* ── share banner ─────────────────────────────────────────────── */
    .share-link-banner {
      padding: 6px 12px;
      background: var(--surface-strong);
      border-bottom: 1px solid var(--line-strong);
      font: 12px/1.4 var(--whilly-mono);
      color: var(--muted);
    }
    .share-link-banner a { color: var(--accent); }
    /* ── Main operator shell ──────────────────────────────────────── */
    .operator-shell {
      width: min(1440px, calc(100vw - 24px));
      margin: 0 auto;
      padding-block: 14px 18px;
    }
    h1, h2, p { margin: 0; }
    h1 { font-size: 1.15rem; line-height: 1.2; }
    h2 { font-size: 0.95rem; line-height: 1.2; }
    .topbar {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--line-strong);
    }
    .operator-controls {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }
    .operator-primary-controls {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }
    .operator-controls input,
    .operator-controls button,
    .operator-identity-panel summary {
      min-height: 32px;
      margin: 0;
      padding: 4px 8px;
      color: var(--text);
      background: var(--surface);
      border: 1px solid var(--line-strong);
      border-radius: 0;
      font: inherit;
      white-space: nowrap;
    }
    .operator-controls button,
    .operator-identity-panel summary {
      cursor: pointer;
    }
    .operator-controls button:hover,
    .operator-controls button:focus-visible,
    .operator-identity-panel summary:hover,
    .operator-identity-panel summary:focus-visible {
      color: var(--surface);
      background: var(--text);
      outline: none;
    }
    .operator-identity-panel {
      min-width: min(100%, 18rem);
      margin: 0;
    }
    .operator-identity-panel summary {
      list-style-position: inside;
      background: var(--surface-strong);
    }
    .operator-identity-fields {
      display: grid;
      gap: 8px;
      margin-top: 8px;
      padding: 8px;
      border: 1px solid var(--line-strong);
      background: var(--surface);
    }
    .operator-identity-fields input {
      width: 100%;
    }
    .surface-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 0;
      margin-block: 8px;
      border: 1px solid var(--line-strong);
      background: var(--surface);
    }
    .surface-tabs button {
      margin: 0;
      padding: 6px 10px;
      color: var(--text);
      background: transparent;
      border: 0;
      border-right: 1px solid var(--line);
      border-radius: 0;
      font: inherit;
      cursor: pointer;
    }
    .surface-tabs button:last-child { border-right: 0; }
    .surface-tabs button[aria-selected="true"] {
      color: var(--surface);
      background: var(--text);
    }
    .operator-surface[hidden] { display: none; }
    .metric-strip {
      display: grid;
      grid-template-columns: repeat(7, minmax(90px, 1fr));
      margin-block: 8px 12px;
      border: 1px solid var(--line-strong);
      background: var(--surface);
    }
    .metric-cell {
      min-width: 0;
      margin: 0;
      padding: 8px 10px;
      border-right: 1px solid var(--line);
    }
    .metric-cell:last-child { border-right: 0; }
    .metric-cell header {
      color: var(--muted);
      font-size: 0.72rem;
      text-transform: uppercase;
    }
    .metric-cell .value {
      margin-top: 2px;
      font-size: 1.05rem;
      font-weight: bold;
      font-variant-numeric: tabular-nums;
    }
    .surface-panel {
      margin-block: 8px 12px;
      padding: 0;
    }
    .surface-panel > header {
      padding: 7px 10px;
      color: var(--text);
      background: var(--surface-strong);
      border: 1px solid var(--line-strong);
      border-bottom: 0;
    }
    .table-wrapper { overflow-x: auto; }
    code { font-family: var(--whilly-mono); color: inherit; }
    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--surface);
      border: 1px solid var(--line-strong);
      font-variant-numeric: tabular-nums;
    }
    th, td {
      padding: 6px 8px;
      text-align: left;
      vertical-align: top;
      border-bottom: 1px solid var(--line);
      white-space: nowrap;
    }
    th {
      color: var(--muted);
      background: var(--surface-strong);
      font-weight: 700;
      text-transform: uppercase;
      font-size: 0.72rem;
    }
    tbody tr:hover { background: color-mix(in srgb, var(--accent) 8%, transparent); }
    tbody tr.review-row-selected { outline: 2px solid var(--accent); outline-offset: -2px; }
    .status, .priority, .review {
      display: inline-block;
      padding: 0;
      border-radius: 0;
      font-size: 0.8rem;
      font-weight: 600;
    }
    .status-online, .status-DONE, .status-done { color: var(--ok); }
    .status-offline, .status-FAILED, .status-failed { color: var(--danger); }
    .status-PENDING, .status-pending { color: var(--muted); }
    .status-CLAIMED, .status-claimed,
    .status-IN_PROGRESS, .status-in_progress { color: var(--warn); }
    .priority-critical { color: var(--danger); }
    .priority-high { color: var(--warn); }
    .priority-medium { color: inherit; }
    .priority-low { opacity: 0.7; }
    .review-approved { color: var(--ok); }
    .review-pending, .review-changes_requested { color: var(--warn); }
    .review-rejected { color: var(--danger); }
    .review-actions {
      display: inline-flex;
      gap: 4px;
      align-items: center;
      white-space: nowrap;
    }
    .review-actions button {
      min-width: 2rem;
      min-height: 32px;
      padding: 4px 8px;
      border: 1px solid var(--line-strong);
      border-radius: 0;
      color: var(--text);
      background: var(--surface);
      font: inherit;
      cursor: pointer;
    }
    .review-actions button:hover,
    .review-actions button:focus-visible {
      color: var(--surface);
      background: var(--text);
      outline: none;
    }
    .review-actions button[data-review-decision="approved"] { border-color: var(--ok); }
    .review-actions button[data-review-decision="rejected"] { border-color: var(--danger); }
    .review-actions button[data-review-decision="changes_requested"] { border-color: var(--warn); }
    .empty-state { opacity: 0.65; }
    .hotkeys, .polling-state, .control-state { opacity: 0.72; }
    .hotkeys {
      display: flex;
      flex-wrap: wrap;
      gap: 2px 18px;
    }
    .polling-state[aria-live] {
      min-width: 4.5rem;
      padding: 5px 8px;
      border: 1px solid var(--line-strong);
      background: var(--surface);
      text-align: center;
    }
    .control-state[aria-live] {
      min-width: 8rem;
      padding: 5px 8px;
      border: 1px solid var(--line-strong);
      background: var(--surface);
      text-align: center;
    }
    .control-state[data-workers-paused="true"] {
      color: var(--warn);
      border-color: var(--warn);
    }
    body[data-dashboard-state="stopped"] .polling-state {
      color: var(--danger);
      border-color: var(--danger);
    }
    .error-banner {
      margin-block: 10px;
      padding: 10px;
      border: 1px solid var(--danger);
      background: var(--surface);
    }
    .error-banner button { margin-top: 0.5rem; }
    footer {
      margin-top: 12px;
      color: var(--muted);
      border-top: 1px solid var(--line);
      padding-top: 8px;
    }
    @media (max-width: 900px) {
      .operator-shell { width: calc(100vw - 16px); padding-block: 8px; }
      .metric-strip { grid-template-columns: repeat(2, 1fr); }
      .topbar { display: block; }
      h1 { font-size: 1rem; }
      .hotkeys { margin-block: 4px 8px; }
      .operator-controls { grid-template-columns: 1fr; }
      .surface-tabs button { flex: 1 0 11rem; text-align: left; }
      table { font-size: 0.85rem; }
      table th, table td { padding: 0.4rem; }
      #surface-compliance .table-wrapper,
      #surface-plans_tasks .table-wrapper,
      #surface-workers .table-wrapper,
      #surface-events .table-wrapper {
        overflow-x: visible;
      }
      #review-gaps,
      #tasks,
      #workers,
      #events {
        display: block;
        width: 100%;
        border: 0;
        background: transparent;
      }
      #review-gaps thead,
      #tasks thead,
      #workers thead,
      #events thead {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        padding: 0;
        overflow: hidden;
        clip: rect(0 0 0 0);
        white-space: nowrap;
        border: 0;
      }
      #review-gaps tbody,
      #tasks tbody,
      #workers tbody,
      #events tbody {
        display: grid;
        gap: 8px;
      }
      #review-gaps tbody tr[data-filter-text],
      #tasks tbody tr[data-filter-text],
      #workers tbody tr[data-filter-text],
      #events tbody tr[data-filter-text] {
        display: grid;
        grid-template-columns: 1fr;
        gap: 4px;
        width: 100%;
        margin: 0 0 8px;
        border: 1px solid var(--line);
        border-radius: 4px;
        background: var(--surface);
        overflow: hidden;
      }
      #review-gaps tbody tr[data-filter-text][hidden],
      #tasks tbody tr[data-filter-text][hidden],
      #workers tbody tr[data-filter-text][hidden],
      #events tbody tr[data-filter-text][hidden] {
        display: none;
      }
      #review-gaps td[data-mobile-label],
      #tasks td[data-mobile-label],
      #workers td[data-mobile-label],
      #events td[data-mobile-label] {
        display: grid;
        grid-template-columns: minmax(84px, 32%) minmax(0, 1fr);
        gap: 8px;
        align-items: start;
        min-width: 0;
        padding: 4px 8px;
        border-bottom: 0;
        white-space: normal;
        overflow-wrap: anywhere;
      }
      #review-gaps td[data-mobile-label]::before,
      #tasks td[data-mobile-label]::before,
      #workers td[data-mobile-label]::before,
      #events td[data-mobile-label]::before {
        content: attr(data-mobile-label);
        color: var(--muted);
        font-size: 12px;
        font-weight: 600;
        line-height: 1.2;
      }
      #review-gaps td[data-mobile-label="Actions"] {
        display: block;
        padding: 8px;
        border-top: 1px solid var(--line);
      }
      #review-gaps td[data-mobile-label="Actions"]::before {
        display: block;
        margin-bottom: 4px;
      }
      #review-gaps .review-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        white-space: normal;
      }
      #review-gaps .review-actions button {
        min-width: 44px;
        min-height: 44px;
        padding: 8px;
      }
      #review-gaps code,
      #review-gaps time,
      #tasks code,
      #tasks time,
      #workers code,
      #workers time,
      #events code,
      #events time {
        white-space: normal;
        overflow-wrap: anywhere;
      }
      #tasks td[data-mobile-label="Review"] code {
        display: block;
        margin-top: 4px;
      }
      #review-gaps-empty,
      #tasks-empty,
      #workers-empty,
      #events-empty {
        display: block;
        border: 1px solid var(--line);
        border-radius: 4px;
        background: var(--surface);
      }
      #review-gaps-empty td,
      #tasks-empty td,
      #workers-empty td,
      #events-empty td {
        display: block;
        padding: 8px;
        white-space: normal;
        border-bottom: 0;
      }
    }
  </style>
</head>
<body class="operator-console" data-dashboard-state="live" hx-ext="sse" sse-connect="/events/stream">
  {# P1.5: session cookie is the primary auth path for SSE now (sent automatically
     for same-origin requests). The ?token= fallback still works server-side during
     the deprecation period (WHILLY_SSE_ACCEPT_URL_TOKEN, default true). #}
  {% if not auth_email and plan_id_for_share_link %}
  <div class="share-link-banner" role="status" data-testid="share-link-banner">
    You're viewing a shared plan. <a href="/login?next=/?plan_id={{ plan_id_for_share_link | urlencode }}">Sign in to manage all plans</a>
  </div>
  {% endif %}
  {% if auth_email %}
  <header class="wui-nav" role="banner" aria-label="WUI session" data-testid="auth-nav">
    <span class="wui-nav__identity">Signed in as <strong>{{ auth_email }}</strong></span>
    <form method="post" action="/auth/logout" class="wui-nav__logout">
      <input type="hidden" name="csrf_token" value="{{ csrf_token | default('') }}">
      <button type="submit">Log out</button>
    </form>
  </header>
  {% endif %}
  {% if auth_email %}
  <section id="wui-plans" aria-label="Plans" class="wui-plans">
    <header class="wui-plans__head">
      <h2>Plans</h2>
      <div class="wui-plans__controls">
        <button type="button" id="new-plan-btn" class="wui-plans__new-btn">+ New Plan</button>
        <input type="search" id="plans-filter" placeholder="Filter by name or plan_id..." aria-label="Filter plans">
        <label><input type="checkbox" id="show-archived"> Show archived</label>
        <span id="archived-count" class="wui-plans__archived-count" aria-live="polite"></span>
        <label class="wui-plans__page-size-label">
          <span class="wui-plans__page-size-text">rows:</span>
          <select id="plans-page-size" aria-label="Rows per page">
            <option value="10">10</option>
            <option value="25" selected>25</option>
            <option value="100">100</option>
          </select>
        </label>
      </div>
    </header>
    <table id="plans-table"
           hx-get="/api/v1/plans"
           hx-trigger="load, refreshPlans from:body"
           hx-swap="none">
      <thead>
        <tr>
          <th data-sort-key="name">Name</th>
          <th data-sort-key="id">ID</th>
          <th data-sort-key="pending">Pending</th>
          <th data-sort-key="in_progress">In progress</th>
          <th data-sort-key="done">Done</th>
          <th data-sort-key="failed">Failed</th>
          <th data-sort-key="budget_usd">Budget</th>
          <th data-sort-key="workers">Workers</th>
          <th data-sort-key="last_event_at">Last active</th>
          <th scope="col" aria-label="Actions"></th>
        </tr>
      </thead>
      <tbody id="plans-table-body">
        <tr class="wui-plans__empty"><td colspan="10">Loading plans...</td></tr>
      </tbody>
    </table>
    <p id="plans-empty-state" class="wui-plans__empty-state" data-testid="plans-table-empty-state" hidden>
      No plans yet. <button type="button" id="new-plan-empty-btn">Create your first plan</button>.
    </p>
    <nav class="wui-plans__pagination" id="plans-pagination" aria-label="Plans table pagination" hidden>
      <span id="plans-pagination-info" class="wui-plans__pagination-info" aria-live="polite"></span>
      <button type="button" id="plans-prev-page" class="wui-plans__pagination-btn" aria-label="Previous page">← prev</button>
      <button type="button" id="plans-next-page" class="wui-plans__pagination-btn" aria-label="Next page">next →</button>
    </nav>

    <!-- PRD-wui-multi-plan v2 Epic B3 — New Plan modal -->
    <dialog id="new-plan-modal" role="dialog" aria-modal="true" aria-labelledby="new-plan-title" data-testid="new-plan-modal">
      <form id="new-plan-form" method="dialog">
        <h3 id="new-plan-title">Create new plan</h3>
        <div class="wui-form-row">
          <label for="plan_id">Plan ID <span class="wui-required">*</span></label>
          <input type="text" id="plan_id" name="plan_id" required
                 maxlength="256" pattern="^[a-z0-9][a-z0-9\-_]{0,254}$"
                 aria-describedby="plan_id-help plan_id-error"
                 autocomplete="off">
          <small id="plan_id-help">lowercase letters, digits, dash, underscore</small>
          <small id="plan_id-error" class="wui-error" role="alert" hidden></small>
        </div>
        <div class="wui-form-row">
          <label for="new-plan-name">Name <span class="wui-required">*</span></label>
          <input type="text" id="new-plan-name" name="name" required maxlength="1024">
        </div>
        <div class="wui-form-row">
          <label for="new-plan-budget">Budget USD (optional)</label>
          <input type="number" id="new-plan-budget" name="budget_usd" step="0.01" min="0">
        </div>
        <small id="new-plan-error" class="wui-error" role="alert" hidden></small>
        <div class="wui-form-actions">
          <button type="button" id="new-plan-cancel">Cancel</button>
          <button type="submit" id="new-plan-submit">Create</button>
        </div>
      </form>
    </dialog>

    <!-- Inline rename / budget modal (reused for both PATCH-name and PATCH-budget paths) -->
    <dialog id="edit-plan-modal" role="dialog" aria-modal="true" aria-labelledby="edit-plan-title" data-testid="edit-plan-modal">
      <form id="edit-plan-form" method="dialog">
        <h3 id="edit-plan-title">Edit plan</h3>
        <input type="hidden" id="edit-plan-id">
        <input type="hidden" id="edit-plan-etag">
        <input type="hidden" id="edit-plan-mode">
        <div class="wui-form-row" id="edit-plan-name-row">
          <label for="edit-plan-name">Name</label>
          <input type="text" id="edit-plan-name" maxlength="1024">
        </div>
        <div class="wui-form-row" id="edit-plan-budget-row">
          <label for="edit-plan-budget">Budget USD</label>
          <input type="number" id="edit-plan-budget" step="0.01" min="0">
        </div>
        <small id="edit-plan-error" class="wui-error" role="alert" hidden></small>
        <div class="wui-form-actions">
          <button type="button" id="edit-plan-cancel">Cancel</button>
          <button type="submit" id="edit-plan-submit">Save</button>
        </div>
      </form>
    </dialog>
    <script>
      (function () {
        var state = {
          plans: [],
          sortKey: "last_event_at",
          sortDir: "desc",
          pageSize: 25,
          currentPage: 1,
        };

        function fetchPlans() {
          var showArchived = document.getElementById("show-archived").checked;
          var url = "/api/v1/plans?include_archived=" + (showArchived ? "true" : "false");
          fetch(url, { credentials: "same-origin", headers: { "Accept": "application/json" } })
            .then(function (r) { return r.ok ? r.json() : { plans: [] }; })
            .then(function (data) {
              state.plans = data.plans || [];
              render();
            })
            .catch(function () { state.plans = []; render(); });
        }

        function clearChildren(node) {
          while (node.firstChild) { node.removeChild(node.firstChild); }
        }

        function makeCell(text) {
          var td = document.createElement("td");
          td.textContent = text == null ? "" : String(text);
          return td;
        }

        function makeCodeCell(text) {
          var td = document.createElement("td");
          var code = document.createElement("code");
          code.textContent = text == null ? "" : String(text);
          td.appendChild(code);
          return td;
        }

        function render() {
          var tbody = document.getElementById("plans-table-body");
          var empty = document.getElementById("plans-empty-state");
          var archivedCount = document.getElementById("archived-count");
          var pagination = document.getElementById("plans-pagination");
          var paginationInfo = document.getElementById("plans-pagination-info");
          var prevBtn = document.getElementById("plans-prev-page");
          var nextBtn = document.getElementById("plans-next-page");
          var filterRaw = (document.getElementById("plans-filter").value || "").toLowerCase();
          var rows = state.plans.slice();
          if (filterRaw) {
            rows = rows.filter(function (p) {
              return (p.name || "").toLowerCase().indexOf(filterRaw) !== -1
                  || (p.id || "").toLowerCase().indexOf(filterRaw) !== -1;
            });
          }
          var archived = rows.filter(function (p) { return p.archived_at != null; }).length;
          archivedCount.textContent = archived > 0 ? "(" + archived + " archived shown)" : "";
          rows.sort(compareRows);
          // ── Pagination: client-side slice. After filter + sort, slice by
          // pageSize and currentPage. Clamp currentPage so a filter change
          // that shrinks the result-set doesn't leave us on an empty page.
          var totalRows = rows.length;
          var pageSize = state.pageSize > 0 ? state.pageSize : totalRows || 1;
          var totalPages = Math.max(1, Math.ceil(totalRows / pageSize));
          if (state.currentPage > totalPages) { state.currentPage = totalPages; }
          if (state.currentPage < 1) { state.currentPage = 1; }
          var startIndex = (state.currentPage - 1) * pageSize;
          var endIndex = Math.min(startIndex + pageSize, totalRows);
          var visibleRows = rows.slice(startIndex, endIndex);
          clearChildren(tbody);
          if (totalRows === 0) {
            empty.hidden = false;
            pagination.hidden = true;
            return;
          }
          empty.hidden = true;
          // Show pagination only when we have more than one page worth.
          if (totalRows > pageSize) {
            pagination.hidden = false;
            paginationInfo.textContent =
              (startIndex + 1) + "–" + endIndex + " of " + totalRows;
            prevBtn.disabled = state.currentPage <= 1;
            nextBtn.disabled = state.currentPage >= totalPages;
          } else {
            pagination.hidden = true;
          }
          visibleRows.forEach(function (p) {
            var counts = p.task_counts || {};
            var inFlight = (counts.in_progress || 0) + (counts.claimed || 0);
            var last = p.last_event_at ? new Date(p.last_event_at).toISOString() : "—";
            var budget = (p.budget_usd == null || p.budget_usd === "") ? "—" : p.budget_usd;
            var tr = document.createElement("tr");
            tr.setAttribute("data-testid", "plan-row");
            tr.setAttribute("data-plan-id", p.id || "");
            if (p.archived_at != null) { tr.setAttribute("data-archived", "true"); }
            tr.tabIndex = 0;
            var tdName = makeCell(p.name || "");
            tr.appendChild(tdName);
            tr.appendChild(makeCodeCell(p.id || ""));
            var tdPending = makeCell(counts.pending || 0);
            tr.appendChild(tdPending);
            tr.appendChild(makeCell(inFlight));
            var tdDone = makeCell(counts.done || 0);
            tr.appendChild(tdDone);
            var tdFailed = makeCell(counts.failed || 0);
            tr.appendChild(tdFailed);
            tr.appendChild(makeCell(budget));
            tr.appendChild(makeCell("—"));
            tr.appendChild(makeCell(last));

            // Actions cell: overflow menu via <details> (lightweight,
            // no extra JS for show/hide). Stops bubble so the row's
            // click-to-navigate handler doesn't fire when the operator
            // is actually targeting the menu.
            var actionsTd = document.createElement("td");
            actionsTd.className = "wui-plans__actions";
            var det = document.createElement("details");
            det.className = "wui-plans__menu";
            var sum = document.createElement("summary");
            sum.textContent = "⋯";  // horizontal ellipsis ⋯
            sum.setAttribute("aria-label", "Plan actions");
            det.appendChild(sum);
            var menu = document.createElement("div");
            menu.className = "wui-plans__menu-body";
            var btnRename = document.createElement("button");
            btnRename.type = "button";
            btnRename.textContent = "Rename";
            btnRename.addEventListener("click", function (ev) { ev.stopPropagation(); det.open = false; openEditModal(p, "name"); });
            var btnBudget = document.createElement("button");
            btnBudget.type = "button";
            btnBudget.textContent = "Edit budget";
            btnBudget.addEventListener("click", function (ev) { ev.stopPropagation(); det.open = false; openEditModal(p, "budget"); });
            var btnArchive = document.createElement("button");
            btnArchive.type = "button";
            var isArchived = p.archived_at != null;
            btnArchive.textContent = isArchived ? "Restore" : "Archive";
            btnArchive.addEventListener("click", function (ev) {
              ev.stopPropagation();
              det.open = false;
              patchPlanArchive(p.id, !isArchived);
            });
            menu.appendChild(btnRename);
            menu.appendChild(btnBudget);
            menu.appendChild(btnArchive);
            det.appendChild(menu);
            // Prevent row-click navigation when interacting with the menu.
            det.addEventListener("click", function (ev) { ev.stopPropagation(); });
            actionsTd.appendChild(det);
            tr.appendChild(actionsTd);

            tr.addEventListener("click", function (ev) {
              // Ignore clicks that originated inside the actions menu.
              if (ev.target && (ev.target.closest && ev.target.closest(".wui-plans__menu"))) return;
              window.location.href = "/plans/" + encodeURIComponent(p.id || "");
            });
            tr.addEventListener("keydown", function (ev) {
              if (ev.key === "Enter" && !(ev.target.closest && ev.target.closest(".wui-plans__menu"))) {
                window.location.href = "/plans/" + encodeURIComponent(p.id || "");
              }
            });
            tbody.appendChild(tr);
          });
        }

        // ── New Plan modal ──────────────────────────────────────────
        function openNewPlanModal() {
          var dlg = document.getElementById("new-plan-modal");
          var planIdInput = document.getElementById("plan_id");
          var nameInput = document.getElementById("new-plan-name");
          var budgetInput = document.getElementById("new-plan-budget");
          planIdInput.value = "";
          nameInput.value = "";
          budgetInput.value = "";
          document.getElementById("plan_id-error").hidden = true;
          document.getElementById("new-plan-error").hidden = true;
          if (typeof dlg.showModal === "function") { dlg.showModal(); } else { dlg.setAttribute("open", ""); }
          setTimeout(function () { planIdInput.focus(); }, 0);
        }
        function closeNewPlanModal() {
          var dlg = document.getElementById("new-plan-modal");
          if (typeof dlg.close === "function") { dlg.close(); } else { dlg.removeAttribute("open"); }
          document.getElementById("new-plan-btn").focus();
        }

        // ── Edit (rename / budget) modal ────────────────────────────
        function openEditModal(plan, mode) {
          var dlg = document.getElementById("edit-plan-modal");
          document.getElementById("edit-plan-id").value = plan.id || "";
          document.getElementById("edit-plan-mode").value = mode;
          document.getElementById("edit-plan-name").value = plan.name || "";
          document.getElementById("edit-plan-budget").value = plan.budget_usd == null ? "" : plan.budget_usd;
          document.getElementById("edit-plan-name-row").hidden = (mode !== "name");
          document.getElementById("edit-plan-budget-row").hidden = (mode !== "budget");
          document.getElementById("edit-plan-error").hidden = true;
          // Fetch fresh ETag for optimistic-concurrency PATCH.
          fetch("/api/v1/plans/" + encodeURIComponent(plan.id || ""), {
            credentials: "same-origin",
            headers: { "Accept": "application/json" }
          }).then(function (r) {
            document.getElementById("edit-plan-etag").value = r.headers.get("ETag") || "";
            if (typeof dlg.showModal === "function") { dlg.showModal(); } else { dlg.setAttribute("open", ""); }
            setTimeout(function () {
              var target = (mode === "name") ? document.getElementById("edit-plan-name") : document.getElementById("edit-plan-budget");
              target.focus();
            }, 0);
          });
        }
        function closeEditModal() {
          var dlg = document.getElementById("edit-plan-modal");
          if (typeof dlg.close === "function") { dlg.close(); } else { dlg.removeAttribute("open"); }
        }

        function submitNewPlan(ev) {
          ev.preventDefault();
          var planIdInput = document.getElementById("plan_id");
          var nameInput = document.getElementById("new-plan-name");
          var budgetInput = document.getElementById("new-plan-budget");
          var pidErr = document.getElementById("plan_id-error");
          var generalErr = document.getElementById("new-plan-error");
          pidErr.hidden = true; generalErr.hidden = true;
          var body = { plan_id: planIdInput.value, name: nameInput.value };
          if (budgetInput.value !== "") {
            body.budget_usd = parseFloat(budgetInput.value);
          }
          fetch("/api/v1/plans", {
            method: "POST",
            credentials: "same-origin",
            headers: { "Accept": "application/json", "Content-Type": "application/json" },
            body: JSON.stringify(body),
          }).then(function (r) {
            if (r.status === 201) {
              closeNewPlanModal();
              fetchPlans();
              return;
            }
            return r.json().then(function (data) {
              if (r.status === 409 && data.error === "plan_exists") {
                pidErr.textContent = "this plan_id already exists";
                pidErr.hidden = false;
                planIdInput.focus();
                return;
              }
              generalErr.textContent = (data && data.detail) ? String(data.detail) : ("Error " + r.status);
              generalErr.hidden = false;
            });
          }).catch(function (e) {
            generalErr.textContent = "Network error: " + e;
            generalErr.hidden = false;
          });
        }

        function submitEditPlan(ev) {
          ev.preventDefault();
          var planId = document.getElementById("edit-plan-id").value;
          var etag = document.getElementById("edit-plan-etag").value;
          var mode = document.getElementById("edit-plan-mode").value;
          var generalErr = document.getElementById("edit-plan-error");
          generalErr.hidden = true;
          var body = {};
          if (mode === "name") {
            body.name = document.getElementById("edit-plan-name").value;
          } else if (mode === "budget") {
            var bv = document.getElementById("edit-plan-budget").value;
            body.budget_usd = (bv === "") ? null : parseFloat(bv);
          }
          fetch("/api/v1/plans/" + encodeURIComponent(planId), {
            method: "PATCH",
            credentials: "same-origin",
            headers: { "Accept": "application/json", "Content-Type": "application/json", "If-Match": etag },
            body: JSON.stringify(body),
          }).then(function (r) {
            if (r.ok) {
              closeEditModal();
              fetchPlans();
              return;
            }
            return r.json().then(function (data) {
              generalErr.textContent = (data && data.detail) ? String(data.detail) : ("Error " + r.status);
              generalErr.hidden = false;
            });
          }).catch(function (e) {
            generalErr.textContent = "Network error: " + e;
            generalErr.hidden = false;
          });
        }

        function patchPlanArchive(planId, archive) {
          // Fetch fresh ETag, then PATCH.
          fetch("/api/v1/plans/" + encodeURIComponent(planId), {
            credentials: "same-origin",
            headers: { "Accept": "application/json" }
          }).then(function (r) {
            var etag = r.headers.get("ETag") || "";
            return fetch("/api/v1/plans/" + encodeURIComponent(planId), {
              method: "PATCH",
              credentials: "same-origin",
              headers: { "Accept": "application/json", "Content-Type": "application/json", "If-Match": etag },
              body: JSON.stringify({ archived: !!archive }),
            });
          }).then(function (r) {
            if (!r.ok) {
              return r.json().then(function (data) {
                alert((data && data.detail) ? data.detail : ("Error " + r.status));
              });
            }
            fetchPlans();
          }).catch(function (e) {
            alert("Network error: " + e);
          });
        }

        function compareRows(a, b) {
          var key = state.sortKey;
          var dir = state.sortDir === "asc" ? 1 : -1;
          var av = extract(a, key);
          var bv = extract(b, key);
          if (av == null && bv == null) return 0;
          if (av == null) return 1;
          if (bv == null) return -1;
          if (av < bv) return -1 * dir;
          if (av > bv) return 1 * dir;
          return (a.id || "").localeCompare(b.id || "");
        }

        function extract(plan, key) {
          var counts = plan.task_counts || {};
          switch (key) {
            case "name": return (plan.name || "").toLowerCase();
            case "id": return (plan.id || "").toLowerCase();
            case "pending": return counts.pending || 0;
            case "in_progress": return (counts.in_progress || 0) + (counts.claimed || 0);
            case "done": return counts.done || 0;
            case "failed": return counts.failed || 0;
            case "budget_usd":
              return plan.budget_usd == null ? null : parseFloat(plan.budget_usd);
            case "workers": return 0;
            case "last_event_at":
              return plan.last_event_at ? Date.parse(plan.last_event_at) : null;
            default: return null;
          }
        }

        document.addEventListener("DOMContentLoaded", function () {
          var headers = document.querySelectorAll("#plans-table thead th[data-sort-key]");
          Array.prototype.forEach.call(headers, function (th) {
            th.style.cursor = "pointer";
            th.addEventListener("click", function () {
              var key = th.getAttribute("data-sort-key");
              if (state.sortKey === key) {
                state.sortDir = state.sortDir === "asc" ? "desc" : "asc";
              } else {
                state.sortKey = key;
                state.sortDir = (key === "name" || key === "id") ? "asc" : "desc";
              }
              render();
            });
          });
          document.getElementById("plans-filter").addEventListener("input", function () {
            // Any new filter resets to the first page so the operator never
            // lands on an empty page after narrowing the result-set.
            state.currentPage = 1;
            render();
          });
          document.getElementById("show-archived").addEventListener("change", fetchPlans);
          document.getElementById("plans-page-size").addEventListener("change", function (e) {
            var n = parseInt(e.target.value, 10);
            state.pageSize = (n === 10 || n === 25 || n === 100) ? n : 25;
            state.currentPage = 1;
            render();
          });
          document.getElementById("plans-prev-page").addEventListener("click", function () {
            if (state.currentPage > 1) { state.currentPage -= 1; render(); }
          });
          document.getElementById("plans-next-page").addEventListener("click", function () {
            state.currentPage += 1;
            render();
          });
          // New-plan modal wiring (PRD Epic B3 + D5 modal pattern).
          document.getElementById("new-plan-btn").addEventListener("click", openNewPlanModal);
          var emptyBtn = document.getElementById("new-plan-empty-btn");
          if (emptyBtn) { emptyBtn.addEventListener("click", openNewPlanModal); }
          document.getElementById("new-plan-cancel").addEventListener("click", closeNewPlanModal);
          document.getElementById("new-plan-form").addEventListener("submit", submitNewPlan);
          document.getElementById("new-plan-modal").addEventListener("cancel", function () {
            // <dialog> emits 'cancel' on Escape; route through closeNewPlanModal
            // so focus management runs uniformly.
            setTimeout(closeNewPlanModal, 0);
          });
          // Edit modal wiring.
          document.getElementById("edit-plan-cancel").addEventListener("click", closeEditModal);
          document.getElementById("edit-plan-form").addEventListener("submit", submitEditPlan);
          document.getElementById("edit-plan-modal").addEventListener("cancel", function () {
            setTimeout(closeEditModal, 0);
          });
          fetchPlans();
        });
      })();
    </script>
  </section>
  {% endif %}
  <main class="operator-shell">
    <header class="topbar">
      <hgroup>
        <h1>Whilly Control Plane</h1>
        <p class="hotkeys">
          <span>q=quit</span>
          <span>r=refresh</span>
          <span>R=resume workers</span>
          <span>{{ surface_switch_hotkey_label }}</span>
          <span>/=filter</span>
          <span>p=pause workers</span>
          <span>j/k=select</span>
          <span>a=Approve review</span>
          <span>x=Reject review</span>
          <span>c=Changes</span>
        </p>
      </hgroup>
      <div class="operator-controls">
        <div class="operator-primary-controls">
          <input id="dashboard-filter"
                 type="search"
                 autocomplete="off"
                 placeholder="Filter tasks, workers, events"
                 aria-label="Filter dashboard rows">
          <button id="dashboard-pause-workers" type="button" data-control-action="pause">Pause workers</button>
          <button id="dashboard-resume-workers" type="button" data-control-action="resume">Resume workers</button>
          <small id="polling-state" class="polling-state" aria-live="polite">Live</small>
          <small id="worker-control-state"
                 class="control-state"
                 data-workers-paused="{{ 'true' if control_state.paused else 'false' }}"
                 aria-live="polite">
            {{ "Workers paused" if control_state.paused else "Workers running" }}
          </small>
        </div>
        <details id="operator-identity-panel" class="operator-identity-panel">
          <summary>Operator identity</summary>
          <div class="operator-identity-fields">
            <input id="dashboard-admin-token"
                   type="password"
                   autocomplete="off"
                   placeholder="Admin bearer"
                   aria-label="Admin bearer token for review actions">
            <input id="dashboard-reviewer"
                   type="email"
                   autocomplete="email"
                   placeholder="Reviewer email"
                   aria-label="Reviewer identity for review actions">
          </div>
        </details>
      </div>
    </header>

    {% if error %}
      <article id="error-banner" class="error-banner" role="alert">
        <header><strong>Control plane unavailable</strong></header>
        <p>{{ error }}</p>
        <button type="button"
                hx-get="/"
                hx-target="body"
                hx-swap="outerHTML"
                hx-trigger="click">Retry</button>
      </article>
    {% endif %}

    <nav class="surface-tabs" role="tablist" aria-label="Operator surfaces">
      {% for surface, label in surfaces %}
        <button type="button"
                id="surface-tab-{{ surface }}"
                role="tab"
                data-surface-tab="{{ surface }}"
                aria-controls="surface-{{ surface }}"
                aria-selected="{{ 'true' if loop.first else 'false' }}">
          {{ loop.index }} {{ label }}
        </button>
      {% endfor %}
    </nav>

    <section class="surface-panel queue-health-panel" aria-label="Queue health">
      <header><h2>Overview · Queue health</h2></header>
      <section class="metric-strip"
               id="summary"
               hx-get="/"
               hx-trigger="every 5s, whilly:reviewDecision from:body, sse:task.created, sse:CLAIM, sse:START, sse:COMPLETE, sse:FAIL, sse:RELEASE, sse:SKIP, sse:task.skipped, sse:worker.registered, sse:worker.heartbeat, sse:worker.revoked, sse:worker.offline, sse:human_review.required, sse:human_review.approved, sse:human_review.rejected, sse:human_review.changes_requested"
               hx-select="#summary"
               hx-target="#summary"
               hx-swap="outerHTML">
        <article class="metric-cell"><header>Tasks</header><div class="value">{{ summary.total_tasks }}</div></article>
        <article class="metric-cell"><header>Active</header><div class="value">{{ summary.tasks_by_status.get("IN_PROGRESS", 0) + summary.tasks_by_status.get("CLAIMED", 0) }}</div></article>
        <article class="metric-cell"><header>Pending</header><div class="value">{{ summary.tasks_by_status.get("PENDING", 0) }}</div></article>
        <article class="metric-cell"><header>Done</header><div class="value">{{ summary.tasks_by_status.get("DONE", 0) }}</div></article>
        <article class="metric-cell"><header>Failed</header><div class="value">{{ summary.failed_tasks }}</div></article>
        <article class="metric-cell"><header>Review</header><div class="value">{{ summary.open_review_gaps }}</div></article>
        <article class="metric-cell"><header>Workers</header><div class="value">{{ summary.workers_online }}/{{ summary.workers_total }}</div></article>
      </section>
    </section>

    <section id="surface-overview" class="operator-surface surface-panel" role="tabpanel" aria-labelledby="surface-tab-overview" data-surface="overview">
      <header><h2>Overview</h2></header>
      <div class="table-wrapper">
        <table id="overview-status" role="grid">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Tasks</td><td>{{ summary.total_tasks }}</td></tr>
            <tr><td>Workers</td><td>{{ summary.workers_online }}/{{ summary.workers_total }} online</td></tr>
            <tr><td>Failed tasks</td><td>{{ summary.failed_tasks }}</td></tr>
            <tr><td>Review gaps</td><td>{{ summary.open_review_gaps }}</td></tr>
            {% for status, count in summary.tasks_by_status.items()|sort %}
              <tr><td>{{ status }}</td><td>{{ count }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>

    <section id="surface-compliance" class="operator-surface surface-panel" role="tabpanel" aria-labelledby="surface-tab-compliance" data-surface="compliance" hidden>
      <header><h2>Compliance - Human review / verification gaps</h2></header>
      <div class="table-wrapper">
        {% set review_columns = table_columns.review_gaps %}
        <table id="review-gaps"
               role="grid"
               hx-get="/"
               hx-trigger="whilly:reviewDecision from:body, sse:human_review.required, sse:human_review.approved, sse:human_review.rejected, sse:human_review.changes_requested"
               hx-select="#review-gaps"
               hx-target="#review-gaps"
               hx-swap="outerHTML">
          <thead>
            <tr>
              {% for column in review_columns %}
                <th scope="col">{{ column.label_for("wui") }}</th>
              {% endfor %}
            </tr>
          </thead>
          <tbody>
            {% if review_gaps %}
              {% for gap in review_gaps %}
                <tr id="review-gap-{{ gap.task_id }}"
                    data-filter-text="{{ gap.task_id }} {{ gap.plan_id }} {{ gap.reason }} {{ gap.stage_id }} {{ gap.reviewer or '' }} {{ gap.approval_channel }}"
                    data-review-task="{{ gap.task_id }}"
                    data-review-stage="{{ gap.stage_id }}"
                    data-review-actionable="{{ 'true' if gap.actionable else 'false' }}"
                    aria-selected="false">
                  <td data-mobile-label="{{ review_columns[0].label_for("wui") }}"><code>{{ gap.task_id }}</code></td>
                  <td data-mobile-label="{{ review_columns[1].label_for("wui") }}">{{ gap.plan_id }}</td>
                  <td data-mobile-label="{{ review_columns[2].label_for("wui") }}">{{ gap.reason }}</td>
                  <td data-mobile-label="{{ review_columns[3].label_for("wui") }}">{{ gap.stage_id if gap.stage_id else "—" }}</td>
                  <td data-mobile-label="{{ review_columns[4].label_for("wui") }}">{{ gap.reviewer if gap.reviewer else "—" }}</td>
                  <td data-mobile-label="{{ review_columns[5].label_for("wui") }}">
                    {% if gap.actionable %}
                      <span class="review-actions" aria-label="Human review actions">
                        <button type="button"
                                data-review-decision="approved"
                                aria-label="Approve review for {{ gap.task_id }}"
                                title="Approve review (a)">A Approve</button>
                        <button type="button"
                                data-review-decision="rejected"
                                aria-label="Reject review for {{ gap.task_id }}"
                                title="Reject review - comment required (x)">X Reject</button>
                        <button type="button"
                                data-review-decision="changes_requested"
                                aria-label="Request changes for {{ gap.task_id }}"
                                title="Request changes - details required (c)">C Changes</button>
                      </span>
                    {% else %}
                      <span class="empty-state">read-only</span>
                    {% endif %}
                  </td>
                </tr>
              {% endfor %}
            {% else %}
              <tr id="review-gaps-empty">
                <td colspan="{{ review_columns|length }}"><em class="empty-state">No human review or verification gaps.</em></td>
              </tr>
            {% endif %}
          </tbody>
        </table>
      </div>
    </section>

    <section id="surface-plans_tasks" class="operator-surface surface-panel" role="tabpanel" aria-labelledby="surface-tab-plans_tasks" data-surface="plans_tasks" hidden>
      <header><h2>Plans/Tasks</h2></header>

      <!-- Jira Import Form (Phase 1 WUI) -->
      <details open class="tui-panel-details" data-testid="jira-import-panel">
        <summary>Import from Jira</summary>
        <div class="tui-panel-body">
          <div class="tui-form-grid">
            <label for="jira-ref" class="tui-form-label">Jira key / URL *</label>
            <input id="jira-ref" type="text" class="tui-inp" placeholder="EORD-9843 or https://jira.../browse/EORD-9843">

            <label for="jira-plan-id" class="tui-form-label">Plan ID override</label>
            <input id="jira-plan-id" type="text" class="tui-inp" placeholder="default: jira-&lt;key-lowercase&gt;">
          </div>
          <label class="tui-check-row">
            <input id="jira-force" type="checkbox">
            Force re-import (overwrite existing plan + tasks)
          </label>

          <div class="tui-btn-row">
            <button id="jira-import-autonomous" type="button" class="tui-btn">
              [bot] Import &amp; Autonomous
            </button>
            <button id="jira-import-wizard" type="button" class="tui-btn tui-btn-secondary">
              [wiz] Import &amp; Wizard
            </button>
            <span id="jira-import-status" class="tui-status" role="status" aria-live="polite"></span>
          </div>

          <!-- Wizard panel (hidden until 'Import & Wizard' is clicked + Jira fetched) -->
          <div id="jira-wizard-panel" hidden
               data-testid="jira-wizard-panel"
               class="tui-wizard-panel">
            <h3>Wizard — refine before agent picks up</h3>
            <p>
              Imported task: <strong id="wizard-task-summary"></strong>
            </p>
            <div class="tui-form-grid">
              <label for="wizard-description" class="tui-form-label">Goal / Description</label>
              <textarea id="wizard-description" rows="4" class="tui-inp" placeholder="Override what the agent should do (markdown ok)"></textarea>

              <label for="wizard-criteria" class="tui-form-label">Acceptance criteria</label>
              <textarea id="wizard-criteria" rows="3" class="tui-inp" placeholder="One per line"></textarea>

              <label for="wizard-key-files" class="tui-form-label">Key files</label>
              <textarea id="wizard-key-files" rows="2" class="tui-inp" placeholder="One path per line"></textarea>

              <label for="wizard-test-steps" class="tui-form-label">Test steps</label>
              <textarea id="wizard-test-steps" rows="2" class="tui-inp" placeholder="One step per line"></textarea>
            </div>
            <div class="tui-btn-row">
              <button id="wizard-submit" type="button" class="tui-btn">
                [ok] Send to agent (autonomous)
              </button>
              <button id="wizard-cancel" type="button" class="tui-btn tui-btn-secondary">
                Cancel
              </button>
              <span id="wizard-status" class="tui-status" role="status" aria-live="polite"></span>
            </div>
          </div>
        </div>
      </details>

      <!-- Task Creation Form -->
      <details class="tui-panel-details">
        <summary>+ Create Task</summary>
        <form id="create-task-form"
              class="tui-panel-body"
              hx-post="/api/v1/tasks"
              hx-trigger="submit"
              hx-swap="none">
          <div class="tui-form-grid">
            <label for="task-id" class="tui-form-label">Task ID *</label>
            <input id="task-id"
                   type="text"
                   name="id"
                   required
                   pattern="[a-zA-Z0-9\-_]+"
                   placeholder="e.g., fix-db-constraint"
                   class="tui-inp">

            <label for="task-priority" class="tui-form-label">Priority</label>
            <select id="task-priority"
                    name="priority"
                    class="tui-inp">
              <option value="low">low</option>
              <option value="medium" selected>medium</option>
              <option value="high">high</option>
              <option value="critical">critical</option>
            </select>

            <label for="task-description" class="tui-form-label">Description</label>
            <textarea id="task-description"
                      name="description"
                      maxlength="2048"
                      rows="3"
                      placeholder="What needs to be done?"
                      class="tui-inp"></textarea>

            <label for="task-dependencies" class="tui-form-label">Dependencies</label>
            <input id="task-dependencies"
                   type="text"
                   name="dependencies"
                   placeholder="Comma-separated task IDs (optional)"
                   class="tui-inp">

            <div style="grid-column: 1 / -1;" class="tui-btn-row">
              <button type="submit" class="tui-btn">[ Create Task ]</button>
              <span id="create-task-status" role="status" aria-live="polite" class="tui-status"></span>
            </div>
          </div>
        </form>
      </details>
      
      <div class="wui-pagination-controls" id="tasks-pagination-controls" data-pager-key="tasks" data-pager-target="tasks">
        <label class="wui-plans__page-size-label">
          <span class="wui-plans__page-size-text">rows:</span>
          <select class="wui-pager-size" aria-label="Tasks rows per page">
            <option value="10">10</option>
            <option value="25" selected>25</option>
            <option value="100">100</option>
          </select>
        </label>
        <span class="wui-pager-info wui-plans__pagination-info" aria-live="polite"></span>
        <button type="button" class="wui-pager-prev wui-plans__pagination-btn" aria-label="Previous page of tasks">← prev</button>
        <button type="button" class="wui-pager-next wui-plans__pagination-btn" aria-label="Next page of tasks">next →</button>
      </div>
      <div class="table-wrapper">
        {% include "_tasks_table.html" %}
      </div>

      <!-- PRD-wui-multi-plan v2 Epic C — Edit Task modal -->
      <dialog id="edit-task-modal" role="dialog" aria-modal="true" aria-labelledby="edit-task-title" data-testid="edit-task-modal">
        <form id="edit-task-form" method="dialog">
          <h3 id="edit-task-title">Edit task</h3>
          <input type="hidden" id="edit-task-id">
          <input type="hidden" id="edit-task-plan-id">
          <input type="hidden" id="edit-task-version">
          <input type="hidden" id="edit-task-claimed-by">
          <div class="wui-form-row">
            <label for="edit-task-description">Description</label>
            <textarea id="edit-task-description" rows="3" maxlength="8192"></textarea>
          </div>
          <div class="wui-form-row">
            <label for="edit-task-priority">Priority</label>
            <select id="edit-task-priority">
              <option value="critical">critical</option>
              <option value="high">high</option>
              <option value="medium">medium</option>
              <option value="low">low</option>
            </select>
          </div>
          <div class="wui-form-row">
            <label for="edit-task-key-files">Key files <small>(one path per line)</small></label>
            <textarea id="edit-task-key-files" rows="3"></textarea>
          </div>
          <div class="wui-form-row">
            <label for="edit-task-acceptance">Acceptance criteria <small>(one per line)</small></label>
            <textarea id="edit-task-acceptance" rows="3"></textarea>
          </div>
          <div class="wui-form-row">
            <label for="edit-task-test-steps">Test steps <small>(one per line)</small></label>
            <textarea id="edit-task-test-steps" rows="3"></textarea>
          </div>
          <div class="wui-form-row">
            <label for="edit-task-dependencies">Dependencies <small>(comma-separated task IDs)</small></label>
            <input type="text" id="edit-task-dependencies" autocomplete="off">
          </div>
          <div id="edit-task-banner" class="wui-banner" role="alert" hidden></div>
          <div id="edit-task-force-release-confirm" class="wui-banner wui-banner--danger" role="alert" hidden>
            <p><strong>This will interrupt the running worker.</strong>
               The task will return to PENDING and may produce a duplicate result.</p>
            <div class="wui-form-actions">
              <button type="button" id="edit-task-force-release-cancel">Cancel</button>
              <button type="button" id="edit-task-force-release-confirm-btn"
                      class="wui-btn--danger" data-testid="force-release-confirm-btn">Confirm release</button>
            </div>
          </div>
          <small id="edit-task-error" class="wui-error" role="alert" hidden></small>
          <div class="wui-form-actions">
            <button type="button" id="edit-task-cancel">Cancel</button>
            <button type="submit" id="edit-task-submit">Save</button>
          </div>
        </form>
      </dialog>
      <script>
        (function () {
          // PRD-wui-multi-plan v2 Block 8 (Epic C) — Edit/Delete task wiring.
          // Operates on the existing #tasks table rendered by
          // _tasks_table.html. Bound at document level via delegation so
          // HTMX refresh (every 5s + SSE) does not strip our handlers
          // along with the swapped rows.
          var lastFocusedTrigger = null;

          function readListAttr(row, name) {
            try { return JSON.parse(row.getAttribute(name) || "[]"); }
            catch (e) { return []; }
          }
          function joinLines(arr) { return (arr || []).join("\n"); }
          function splitLines(text) {
            return (text || "").split(/\r?\n/).map(function (s) { return s.trim(); })
              .filter(function (s) { return s.length > 0; });
          }
          function splitCommas(text) {
            return (text || "").split(/[,;]/).map(function (s) { return s.trim(); })
              .filter(function (s) { return s.length > 0; });
          }

          function openEditTaskModal(row, trigger) {
            lastFocusedTrigger = trigger || null;
            var dlg = document.getElementById("edit-task-modal");
            document.getElementById("edit-task-id").value = row.getAttribute("data-task-id") || "";
            document.getElementById("edit-task-plan-id").value = row.getAttribute("data-plan-id") || "";
            document.getElementById("edit-task-version").value = row.getAttribute("data-version") || "0";
            document.getElementById("edit-task-claimed-by").value = row.getAttribute("data-claimed-by") || "";
            document.getElementById("edit-task-description").value = row.getAttribute("data-description") || "";
            document.getElementById("edit-task-priority").value = row.getAttribute("data-priority") || "medium";
            document.getElementById("edit-task-key-files").value = joinLines(readListAttr(row, "data-key-files"));
            document.getElementById("edit-task-acceptance").value = joinLines(readListAttr(row, "data-acceptance-criteria"));
            document.getElementById("edit-task-test-steps").value = joinLines(readListAttr(row, "data-test-steps"));
            document.getElementById("edit-task-dependencies").value = (readListAttr(row, "data-dependencies") || []).join(", ");
            document.getElementById("edit-task-banner").hidden = true;
            document.getElementById("edit-task-force-release-confirm").hidden = true;
            document.getElementById("edit-task-error").hidden = true;
            if (typeof dlg.showModal === "function") { dlg.showModal(); }
            else { dlg.setAttribute("open", ""); }
            setTimeout(function () { document.getElementById("edit-task-description").focus(); }, 0);
          }
          function closeEditTaskModal() {
            var dlg = document.getElementById("edit-task-modal");
            if (typeof dlg.close === "function") { dlg.close(); } else { dlg.removeAttribute("open"); }
            if (lastFocusedTrigger && typeof lastFocusedTrigger.focus === "function") {
              try { lastFocusedTrigger.focus(); } catch (e) { /* row gone after HTMX swap */ }
            }
          }

          function showBanner(html, opts) {
            var banner = document.getElementById("edit-task-banner");
            banner.innerHTML = html;
            banner.hidden = false;
            if (opts && opts.danger) { banner.classList.add("wui-banner--danger"); }
            else { banner.classList.remove("wui-banner--danger"); }
          }

          function submitEditTask(ev) {
            ev.preventDefault();
            var taskId = document.getElementById("edit-task-id").value;
            var planId = document.getElementById("edit-task-plan-id").value;
            var version = document.getElementById("edit-task-version").value;
            var body = {
              description: document.getElementById("edit-task-description").value,
              priority: document.getElementById("edit-task-priority").value,
              key_files: splitLines(document.getElementById("edit-task-key-files").value),
              acceptance_criteria: splitLines(document.getElementById("edit-task-acceptance").value),
              test_steps: splitLines(document.getElementById("edit-task-test-steps").value),
              dependencies: splitCommas(document.getElementById("edit-task-dependencies").value),
            };
            var ifMatch = 'W/"v' + parseInt(version || "0", 10) + '"';
            fetch("/api/v1/tasks/" + encodeURIComponent(taskId) + "?plan_id=" + encodeURIComponent(planId), {
              method: "PATCH",
              credentials: "same-origin",
              headers: { "Accept": "application/json", "Content-Type": "application/json", "If-Match": ifMatch },
              body: JSON.stringify(body),
            }).then(function (r) {
              if (r.ok) {
                closeEditTaskModal();
                if (window.htmx) { window.htmx.ajax("GET", "/?fragment=tasks", { target: "#tasks", swap: "outerHTML" }); }
                return;
              }
              return r.json().then(function (data) {
                if (r.status === 412) {
                  showBanner(
                    "This task changed since you opened the modal. "
                    + '<button type="button" id="edit-task-reload-btn">Reload current values</button> '
                    + '<button type="button" id="edit-task-cancel-412">Cancel</button>'
                  );
                  document.getElementById("edit-task-reload-btn").addEventListener("click", function () {
                    if (window.htmx) {
                      window.htmx.ajax("GET", "/?fragment=tasks", { target: "#tasks", swap: "outerHTML" })
                        .then(function () {
                          var fresh = document.querySelector('#tasks tr[data-task-id="' + CSS.escape(taskId) + '"]');
                          if (fresh) { openEditTaskModal(fresh, lastFocusedTrigger); }
                          else { closeEditTaskModal(); }
                        });
                    }
                  });
                  document.getElementById("edit-task-cancel-412").addEventListener("click", closeEditTaskModal);
                  return;
                }
                if (r.status === 409 && data && data.error === "task_claimed") {
                  var workerHtml = data.worker_id ? ("worker <code>" + data.worker_id + "</code>") : "a worker";
                  showBanner(
                    "Task is in " + workerHtml + ". "
                    + '<button type="button" id="edit-task-show-force-release">Force release</button> '
                    + '<button type="button" id="edit-task-cancel-409">Cancel</button>',
                    { danger: true }
                  );
                  document.getElementById("edit-task-show-force-release").addEventListener("click", function () {
                    document.getElementById("edit-task-force-release-confirm").hidden = false;
                  });
                  document.getElementById("edit-task-cancel-409").addEventListener("click", closeEditTaskModal);
                  return;
                }
                var err = document.getElementById("edit-task-error");
                err.textContent = (data && data.detail) ? String(data.detail) : ("Error " + r.status);
                err.hidden = false;
              });
            }).catch(function (e) {
              var err = document.getElementById("edit-task-error");
              err.textContent = "Network error: " + e;
              err.hidden = false;
            });
          }

          function forceReleaseConfirmed() {
            // PRD C5: two-step Force release inside the modal.
            var taskId = document.getElementById("edit-task-id").value;
            var workerId = document.getElementById("edit-task-claimed-by").value;
            // Build a minimal ReleaseRequest; the existing worker endpoint
            // requires worker_id + version + reason. We don't carry the
            // task's CLAIMED version in the DOM, so we re-fetch.
            fetch("/api/v1/tasks?plan_id=" + encodeURIComponent(document.getElementById("edit-task-plan-id").value), {
              credentials: "same-origin",
              headers: { "Accept": "application/json" }
            }).then(function (r) { return r.ok ? r.json() : { tasks: [] }; })
              .then(function (data) {
                var match = (data.tasks || []).filter(function (t) { return t.id === taskId; })[0];
                if (!match) { throw new Error("task not found after refetch"); }
                return fetch("/tasks/" + encodeURIComponent(taskId) + "/release", {
                  method: "POST",
                  credentials: "same-origin",
                  headers: { "Accept": "application/json", "Content-Type": "application/json" },
                  body: JSON.stringify({
                    worker_id: workerId,
                    version: match.version,
                    reason: "operator force-release via WUI"
                  })
                });
              }).then(function (r) {
                if (!r.ok) {
                  return r.json().then(function (data) {
                    var err = document.getElementById("edit-task-error");
                    err.textContent = (data && data.detail) ? String(data.detail) : ("Release error " + r.status);
                    err.hidden = false;
                  });
                }
                document.getElementById("edit-task-force-release-confirm").hidden = true;
                document.getElementById("edit-task-banner").hidden = true;
                if (window.htmx) { window.htmx.ajax("GET", "/?fragment=tasks", { target: "#tasks", swap: "outerHTML" }); }
                closeEditTaskModal();
              }).catch(function (e) {
                var err = document.getElementById("edit-task-error");
                err.textContent = "Network error: " + e;
                err.hidden = false;
              });
          }

          function deleteTaskWithConfirm(row, btn) {
            // PRD C3: two-step inline confirm. Reuses the row cell so the
            // operator's attention does not jump out of the table.
            var cell = btn.parentNode;
            var original = cell.innerHTML;
            var taskId = row.getAttribute("data-task-id");
            cell.innerHTML = '<span class="wui-inline-confirm">Delete <code>' + taskId
              + '</code>? <button type="button" class="task-delete-confirm wui-btn--danger">Confirm</button> '
              + '<button type="button" class="task-delete-cancel">Cancel</button></span>';
            cell.querySelector(".task-delete-cancel").addEventListener("click", function () {
              cell.innerHTML = original;
              // Re-bind the now-recreated edit/delete buttons.
              wireRowButtons(row);
            });
            cell.querySelector(".task-delete-confirm").addEventListener("click", function () {
              var planId = row.getAttribute("data-plan-id");
              var version = row.getAttribute("data-version") || "0";
              var ifMatch = 'W/"v' + parseInt(version, 10) + '"';
              fetch("/api/v1/tasks/" + encodeURIComponent(taskId) + "?plan_id=" + encodeURIComponent(planId), {
                method: "DELETE",
                credentials: "same-origin",
                headers: { "Accept": "application/json", "If-Match": ifMatch }
              }).then(function (r) {
                if (r.status === 204) {
                  if (window.htmx) { window.htmx.ajax("GET", "/?fragment=tasks", { target: "#tasks", swap: "outerHTML" }); }
                  return;
                }
                return r.json().then(function (data) {
                  alert((data && data.detail) ? data.detail : ("Error " + r.status));
                  cell.innerHTML = original;
                  wireRowButtons(row);
                });
              }).catch(function (e) {
                alert("Network error: " + e);
                cell.innerHTML = original;
                wireRowButtons(row);
              });
            });
          }

          function wireRowButtons(row) {
            // Idempotent — safe to call after each HTMX swap.
            var editBtn = row.querySelector(".task-edit-btn");
            var delBtn = row.querySelector(".task-delete-btn");
            if (editBtn && !editBtn.dataset.bound) {
              editBtn.dataset.bound = "1";
              editBtn.addEventListener("click", function () { openEditTaskModal(row, editBtn); });
            }
            if (delBtn && !delBtn.dataset.bound) {
              delBtn.dataset.bound = "1";
              delBtn.addEventListener("click", function () { deleteTaskWithConfirm(row, delBtn); });
            }
          }

          function wireAllRows() {
            var rows = document.querySelectorAll('#tasks tr[data-task-id]');
            Array.prototype.forEach.call(rows, wireRowButtons);
          }

          document.addEventListener("DOMContentLoaded", function () {
            wireAllRows();
            document.getElementById("edit-task-cancel").addEventListener("click", closeEditTaskModal);
            document.getElementById("edit-task-form").addEventListener("submit", submitEditTask);
            document.getElementById("edit-task-modal").addEventListener("cancel", function () {
              setTimeout(closeEditTaskModal, 0);
            });
            document.getElementById("edit-task-force-release-cancel").addEventListener("click", function () {
              document.getElementById("edit-task-force-release-confirm").hidden = true;
            });
            document.getElementById("edit-task-force-release-confirm-btn").addEventListener("click", forceReleaseConfirmed);
          });
          // HTMX swap re-renders the table — re-bind buttons each time.
          document.body.addEventListener("htmx:afterSwap", function (ev) {
            if (ev && ev.target && ev.target.id === "tasks") { wireAllRows(); }
          });

          // ── Generic table pagination (tasks + workers) ────────────────
          // Tables come from server-side fragments (limit=200), HTMX swaps
          // them every 5 s. JS slice via display:none keeps the operator's
          // page-size + current-page across swaps. Page state persists in
          // localStorage so a refresh / re-login lands on the same page.
          function wuiPager(controlsId) {
            var controls = document.getElementById(controlsId);
            if (!controls) return;
            var pagerKey = controls.dataset.pagerKey;
            var targetId = controls.dataset.pagerTarget;
            var sizeSelect = controls.querySelector(".wui-pager-size");
            var info = controls.querySelector(".wui-pager-info");
            var prevBtn = controls.querySelector(".wui-pager-prev");
            var nextBtn = controls.querySelector(".wui-pager-next");
            var storageKey = "wui-pager:" + pagerKey;
            var saved = {};
            try { saved = JSON.parse(localStorage.getItem(storageKey) || "{}"); } catch (e) {}
            var pageSize = (saved.pageSize === 10 || saved.pageSize === 25 || saved.pageSize === 100)
              ? saved.pageSize : 25;
            var currentPage = saved.currentPage > 0 ? saved.currentPage : 1;
            sizeSelect.value = String(pageSize);

            function persist() {
              try {
                localStorage.setItem(storageKey, JSON.stringify({
                  pageSize: pageSize, currentPage: currentPage,
                }));
              } catch (e) {}
            }
            function getDataRows() {
              var table = document.getElementById(targetId);
              if (!table) return [];
              // Skip the empty-state row (only one td with colspan).
              return Array.prototype.filter.call(
                table.tBodies[0] ? table.tBodies[0].rows : [],
                function (tr) { return tr.cells.length > 1; }
              );
            }
            function apply() {
              var rows = getDataRows();
              var total = rows.length;
              if (total === 0) {
                controls.hidden = true;
                return;
              }
              var totalPages = Math.max(1, Math.ceil(total / pageSize));
              if (currentPage > totalPages) currentPage = totalPages;
              if (currentPage < 1) currentPage = 1;
              var start = (currentPage - 1) * pageSize;
              var end = Math.min(start + pageSize, total);
              rows.forEach(function (tr, i) {
                tr.style.display = (i >= start && i < end) ? "" : "none";
              });
              controls.hidden = total <= pageSize ? false : false;  // always shown when there are rows
              info.textContent = (start + 1) + "–" + end + " of " + total;
              prevBtn.disabled = currentPage <= 1;
              nextBtn.disabled = currentPage >= totalPages;
              persist();
            }
            sizeSelect.addEventListener("change", function (e) {
              var n = parseInt(e.target.value, 10);
              pageSize = (n === 10 || n === 25 || n === 100) ? n : 25;
              currentPage = 1;
              apply();
            });
            prevBtn.addEventListener("click", function () {
              if (currentPage > 1) { currentPage -= 1; apply(); }
            });
            nextBtn.addEventListener("click", function () {
              currentPage += 1; apply();
            });
            // Re-apply on every HTMX swap that replaces our target.
            document.body.addEventListener("htmx:afterSwap", function (ev) {
              if (ev && ev.target && ev.target.id === targetId) { apply(); }
            });
            apply();
          }
          wuiPager("tasks-pagination-controls");
          wuiPager("workers-pagination-controls");
        })();
      </script>
    </section>

    <section id="surface-workers" class="operator-surface surface-panel" role="tabpanel" aria-labelledby="surface-tab-workers" data-surface="workers" hidden>
      <header><h2>Workers</h2></header>
      <div class="wui-pagination-controls" id="workers-pagination-controls" data-pager-key="workers" data-pager-target="workers">
        <label class="wui-plans__page-size-label">
          <span class="wui-plans__page-size-text">rows:</span>
          <select class="wui-pager-size" aria-label="Workers rows per page">
            <option value="10">10</option>
            <option value="25" selected>25</option>
            <option value="100">100</option>
          </select>
        </label>
        <span class="wui-pager-info wui-plans__pagination-info" aria-live="polite"></span>
        <button type="button" class="wui-pager-prev wui-plans__pagination-btn" aria-label="Previous page of workers">← prev</button>
        <button type="button" class="wui-pager-next wui-plans__pagination-btn" aria-label="Next page of workers">next →</button>
      </div>
      <div class="table-wrapper">
        {% include "_workers_table.html" %}
      </div>
    </section>

    <section id="surface-events" class="operator-surface surface-panel" role="tabpanel" aria-labelledby="surface-tab-events" data-surface="events" hidden>
      <header><h2>Events</h2></header>
      <div class="table-wrapper">
        {% set event_columns = table_columns.events %}
        <table id="events" role="grid">
          <thead>
            <tr>
              {% for column in event_columns %}
                <th scope="col">{{ column.label_for("wui") }}</th>
              {% endfor %}
            </tr>
          </thead>
          <tbody>
            {% if events %}
              {% for event in events %}
                <tr id="event-{{ event.event_id }}"
                    data-filter-text="{{ event.event_id }} {{ event.task_id or '' }} {{ event.plan_id or '' }} {{ event.event_type }} {{ event.detail }}">
                  <td data-mobile-label="{{ event_columns[0].label_for("wui") }}"><code>{{ event.event_id }}</code></td>
                  <td data-mobile-label="{{ event_columns[1].label_for("wui") }}">{{ event.task_id if event.task_id else "—" }}</td>
                  <td data-mobile-label="{{ event_columns[2].label_for("wui") }}">{{ event.plan_id if event.plan_id else "—" }}</td>
                  <td data-mobile-label="{{ event_columns[3].label_for("wui") }}">{{ event.event_type }}</td>
                  <td data-mobile-label="{{ event_columns[4].label_for("wui") }}"><time datetime="{{ format_iso(event.created_at) }}">{{ format_human(event.created_at) }}</time></td>
                </tr>
              {% endfor %}
            {% else %}
              <tr id="events-empty">
                <td colspan="{{ event_columns|length }}"><em class="empty-state">No events recorded.</em></td>
              </tr>
            {% endif %}
          </tbody>
        </table>
      </div>
    </section>

    <footer>
      <small>Whilly v{{ version }} &middot; rendered {{ rendered_at_human }}</small>
    </footer>
  </main>
  <script>
    (() => {
      const DASHBOARD_STATE_KEY = "whilly.operator.dashboard.state.v1";
      const surfaceOrder = {{ surface_order_json | safe }};
      const workerControlRoutePrefix = "{{ wui_route_prefixes.worker_control }}";
      const taskHumanReviewRoutePrefix = "{{ wui_route_prefixes.task_human_review }}";
      const restorableFocusIds = new Set(["dashboard-filter", "dashboard-admin-token", "dashboard-reviewer"]);
      const filter = document.getElementById("dashboard-filter");
      const pollingState = document.getElementById("polling-state");
      const workerControlState = document.getElementById("worker-control-state");
      let dashboardStopped = false;
      let manualRefreshRequested = false;
      let selectedReviewIndex = 0;
      let restoringDashboardState = false;
      const liveStreams = new Set();

      function isEditableTarget(target) {
        if (!target) return false;
        const tag = target.tagName;
        return target.isContentEditable || tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT";
      }

      function readDashboardState() {
        try {
          const raw = window.sessionStorage?.getItem(DASHBOARD_STATE_KEY);
          if (!raw) return {};
          const parsed = JSON.parse(raw);
          return parsed && typeof parsed === "object" ? parsed : {};
        } catch {
          return {};
        }
      }

      function focusedDashboardInputId() {
        const active = document.activeElement;
        if (!active?.id || !restorableFocusIds.has(active.id)) return "";
        return active.id;
      }

      function saveDashboardState() {
        if (restoringDashboardState) return;
        try {
          window.sessionStorage?.setItem(DASHBOARD_STATE_KEY, JSON.stringify({
            surface: currentSurface(),
            filterText: filter?.value || "",
            selectedReviewIndex,
            focusId: focusedDashboardInputId(),
          }));
        } catch {
          // Browser storage can be unavailable in private or embedded contexts.
        }
      }

      function restoreDashboardFocus(focusId) {
        if (!focusId || !restorableFocusIds.has(focusId)) return;
        const target = document.getElementById(focusId);
        const panel = target?.closest("details");
        if (panel) panel.open = true;
        if (target && typeof target.focus === "function") target.focus();
      }

      function restoreDashboardState() {
        const state = readDashboardState();
        restoringDashboardState = true;
        try {
          const surface = surfaceOrder.includes(state.surface) ? state.surface : "overview";
          setSurface(surface);
          if (filter && typeof state.filterText === "string") filter.value = state.filterText;
          const index = Number.parseInt(String(state.selectedReviewIndex ?? "0"), 10);
          selectedReviewIndex = Number.isFinite(index) ? Math.max(0, index) : 0;
          applyFilter();
          restoreDashboardFocus(state.focusId);
        } finally {
          restoringDashboardState = false;
        }
      }

      function setSurface(surface) {
        document.querySelectorAll("[data-surface]").forEach((section) => {
          section.hidden = section.dataset.surface !== surface;
        });
        document.querySelectorAll("[data-surface-tab]").forEach((button) => {
          button.setAttribute("aria-selected", String(button.dataset.surfaceTab === surface));
        });
        saveDashboardState();
      }

      function currentSurface() {
        const selected = document.querySelector("[data-surface-tab][aria-selected='true']");
        return selected?.dataset.surfaceTab || "overview";
      }

      function isComplianceSurface() {
        return currentSurface() === "compliance";
      }

      function applyFilter() {
        const needle = (filter?.value || "").trim().toLowerCase();
        document.querySelectorAll("tbody tr[data-filter-text]").forEach((row) => {
          row.hidden = Boolean(needle) && !row.dataset.filterText.toLowerCase().includes(needle);
        });
        selectReviewRow(selectedReviewIndex);
        saveDashboardState();
      }

      function refreshDashboard() {
        if (dashboardStopped) return;
        saveDashboardState();
        if (window.htmx) {
          manualRefreshRequested = true;
          window.htmx.ajax("GET", "/", { target: "body", swap: "outerHTML" });
          return;
        }
        window.location.reload();
      }

      function closeLiveStreams() {
        liveStreams.forEach((source) => {
          if (source && typeof source.close === "function") source.close();
        });
        liveStreams.clear();
        document.body.removeAttribute("sse-connect");
      }

      function quitDashboard() {
        dashboardStopped = true;
        closeLiveStreams();
        document.body.dataset.dashboardState = "stopped";
        setPollingStatus("Stopped", true);
      }

      function setPollingStatus(text, isError = false) {
        if (!pollingState) return;
        pollingState.textContent = text;
        pollingState.dataset.state = isError ? "error" : "ok";
      }

      function setWorkerControlStatus(paused) {
        if (!workerControlState) return;
        workerControlState.dataset.workersPaused = String(paused);
        workerControlState.textContent = paused ? "Workers paused" : "Workers running";
      }

      function actionableReviewRows() {
        return Array.from(document.querySelectorAll('#review-gaps tbody tr[data-review-actionable="true"]'))
          .filter((row) => !row.hidden);
      }

      function selectReviewRow(index) {
        const rows = actionableReviewRows();
        document.querySelectorAll("#review-gaps tbody tr[data-review-task]").forEach((row) => {
          row.classList.remove("review-row-selected");
          row.setAttribute("aria-selected", "false");
        });
        if (!rows.length) {
          selectedReviewIndex = 0;
          return null;
        }
        selectedReviewIndex = Math.max(0, Math.min(index, rows.length - 1));
        const selected = rows[selectedReviewIndex];
        selected.classList.add("review-row-selected");
        selected.setAttribute("aria-selected", "true");
        saveDashboardState();
        return selected;
      }

      function selectedReviewRow() {
        return selectReviewRow(selectedReviewIndex);
      }

      function refreshReviewFragments() {
        saveDashboardState();
        if (window.htmx) {
          manualRefreshRequested = true;
          window.htmx.trigger(document.body, "whilly:reviewDecision");
          return;
        }
        refreshDashboard();
      }

      async function submitControlAction(action) {
        if (dashboardStopped) return;
        const adminToken = document.getElementById("dashboard-admin-token");
        const token = (adminToken?.value || "").trim();
        if (!token) {
          setPollingStatus("Admin token required", true);
          adminToken?.focus();
          return;
        }
        const payload = {};
        if (action === "pause") {
          const reason = window.prompt("Pause reason", "");
          if (reason === null) return;
          if (reason.trim()) payload.reason = reason.trim();
        }
        setPollingStatus(action === "pause" ? "Pausing" : "Resuming");
        try {
          const response = await fetch(`${workerControlRoutePrefix}${action}`, {
            method: "POST",
            headers: {
              "Authorization": `Bearer ${token}`,
              "Content-Type": "application/json",
            },
            body: JSON.stringify(payload),
          });
          if (!response.ok) {
            let detail = response.statusText;
            try {
              const body = await response.json();
              detail = body.detail || body.error || detail;
            } catch {
              detail = response.statusText;
            }
            setPollingStatus(`Control ${response.status}: ${detail}`, true);
            return;
          }
          const state = await response.json();
          setWorkerControlStatus(Boolean(state.paused));
          setPollingStatus(state.paused ? "Workers paused" : "Workers resumed");
          refreshDashboard();
        } catch (error) {
          setPollingStatus(`Control error: ${error}`, true);
        }
      }

      async function submitReviewDecision(row, decision) {
        if (!row) {
          setPollingStatus("No review row selected", true);
          return;
        }
        const adminToken = document.getElementById("dashboard-admin-token");
        const reviewerInput = document.getElementById("dashboard-reviewer");
        const token = (adminToken?.value || "").trim();
        const reviewer = (reviewerInput?.value || "").trim();
        if (!token) {
          setPollingStatus("Admin token required", true);
          adminToken?.focus();
          return;
        }
        if (!reviewer) {
          setPollingStatus("Reviewer required", true);
          reviewerInput?.focus();
          return;
        }
        const taskId = row.dataset.reviewTask || "";
        const payload = { decision, reviewer };
        if (row.dataset.reviewStage) payload.stage_id = row.dataset.reviewStage;
        if (decision === "rejected") {
          const comment = window.prompt("Reject review: enter required comment", "");
          if (comment === null) {
            setPollingStatus("Reject canceled");
            return;
          }
          if (!comment.trim()) {
            setPollingStatus("Reject requires a comment", true);
            return;
          }
          payload.comment = comment.trim();
        }
        if (decision === "changes_requested") {
          const requested = window.prompt("Request changes: describe required changes", "");
          if (requested === null) {
            setPollingStatus("Changes canceled");
            return;
          }
          if (!requested.trim()) {
            setPollingStatus("Changes requires details", true);
            return;
          }
          payload.requested_changes = [requested.trim()];
        }
        setPollingStatus("Recording");
        try {
          const response = await fetch(`${taskHumanReviewRoutePrefix}${encodeURIComponent(taskId)}/human-review`, {
            method: "POST",
            headers: {
              "Authorization": `Bearer ${token}`,
              "Content-Type": "application/json",
            },
            body: JSON.stringify(payload),
          });
          if (!response.ok) {
            let detail = response.statusText;
            try {
              const body = await response.json();
              detail = body.detail || body.error || detail;
            } catch {
              detail = response.statusText;
            }
            setPollingStatus(
              `Review not recorded: ${detail}. Check admin token, reviewer, and selected row, then retry.`,
              true
            );
            return;
          }
          const recordedMessages = {
            approved: "Review recorded: approved",
            rejected: "Review recorded: rejected",
            changes_requested: "Review recorded: changes requested",
          };
          setPollingStatus(recordedMessages[decision] || `Review recorded: ${decision}`);
          refreshReviewFragments();
        } catch (error) {
          setPollingStatus(
            `Review not recorded: ${error}. Check admin token, reviewer, and selected row, then retry.`,
            true
          );
        }
      }

      function isManualLiveIntent(event, triggerType = "") {
        const type = triggerType || event?.detail?.requestConfig?.triggeringEvent?.type || "";
        return manualRefreshRequested || type === "click";
      }

      function markManualLiveRequest(event) {
        manualRefreshRequested = false;
      }

      filter?.addEventListener("input", applyFilter);
      document.querySelectorAll("[data-surface-tab]").forEach((button) => {
        button.addEventListener("click", () => setSurface(button.dataset.surfaceTab));
      });
      document.body.addEventListener("click", (event) => {
        const controlButton = event.target.closest?.("[data-control-action]");
        if (controlButton) {
          event.preventDefault();
          submitControlAction(controlButton.dataset.controlAction);
          return;
        }
        const actionButton = event.target.closest?.("[data-review-decision]");
        if (actionButton) {
          const row = actionButton.closest("tr[data-review-task]");
          event.preventDefault();
          submitReviewDecision(row, actionButton.dataset.reviewDecision);
          return;
        }
        const reviewRow = event.target.closest?.("#review-gaps tbody tr[data-review-actionable='true']");
        if (reviewRow) {
          const rows = actionableReviewRows();
          selectedReviewIndex = Math.max(0, rows.indexOf(reviewRow));
          selectReviewRow(selectedReviewIndex);
        }
      });
      document.body.addEventListener("htmx:sseOpen", (event) => {
        const source = event.detail?.source || event.detail?.eventSource;
        if (source) liveStreams.add(source);
      });
      document.body.addEventListener("htmx:beforeRequest", (event) => {
        const triggerType = event.detail?.requestConfig?.triggeringEvent?.type || "";
        if (dashboardStopped) {
          manualRefreshRequested = false;
          event.preventDefault();
          return;
        }
        saveDashboardState();
        if (isManualLiveIntent(event, triggerType)) markManualLiveRequest(event);
      });
      document.body.addEventListener("htmx:afterRequest", () => {
        manualRefreshRequested = false;
      });
      document.body.addEventListener("htmx:sendError", () => {
        manualRefreshRequested = false;
      });
      document.body.addEventListener("htmx:afterSwap", () => {
        restoreDashboardState();
      });
      document.addEventListener("keydown", (event) => {
        if (isEditableTarget(event.target)) return;
        if (event.key === "q" || event.key === "Q") {
          event.preventDefault();
          quitDashboard();
        } else if (event.key === "r") {
          event.preventDefault();
          refreshDashboard();
        } else if (event.key === "R") {
          event.preventDefault();
          submitControlAction("resume");
        } else if (event.key === "p" || event.key === "P") {
          event.preventDefault();
          submitControlAction("pause");
        } else if (isComplianceSurface() && (event.key === "j" || event.key === "J")) {
          event.preventDefault();
          selectReviewRow(selectedReviewIndex + 1);
        } else if (isComplianceSurface() && (event.key === "k" || event.key === "K")) {
          event.preventDefault();
          selectReviewRow(selectedReviewIndex - 1);
        } else if (isComplianceSurface() && (event.key === "a" || event.key === "A")) {
          event.preventDefault();
          submitReviewDecision(selectedReviewRow(), "approved");
        } else if (isComplianceSurface() && (event.key === "x" || event.key === "X")) {
          event.preventDefault();
          submitReviewDecision(selectedReviewRow(), "rejected");
        } else if (isComplianceSurface() && (event.key === "c" || event.key === "C")) {
          event.preventDefault();
          submitReviewDecision(selectedReviewRow(), "changes_requested");
        } else if (event.key === "/") {
          event.preventDefault();
          filter?.focus();
        } else if (/^[1-5]$/.test(event.key)) {
          event.preventDefault();
          setSurface(surfaceOrder[Number(event.key) - 1]);
        }
      });
      // Task creation form handler
      const createTaskForm = document.getElementById("create-task-form");
      if (createTaskForm) {
        // Convert form data to JSON with proper array handling
        createTaskForm.addEventListener("submit", (event) => {
          event.preventDefault();
          const formData = new FormData(createTaskForm);
          const payload = Object.fromEntries(formData);
          
          // Parse dependencies as array
          if (payload.dependencies && typeof payload.dependencies === "string") {
            payload.dependencies = payload.dependencies
              .split(/[,;]/)
              .map((s) => s.trim())
              .filter((s) => s);
          } else {
            payload.dependencies = [];
          }
          
          // Resolve plan_id from either /plans/<id> path or ?plan_id= query.
          // Path takes precedence so the form on /plans/foo POSTs to plan
          // "foo" without depending on a query parameter being present.
          const urlParams = new URLSearchParams(window.location.search);
          const pathMatch = window.location.pathname.match(/^\/plans\/([^/?#]+)/);
          const planId = (pathMatch && decodeURIComponent(pathMatch[1])) || urlParams.get("plan_id") || "default";
          const token = urlParams.get("token") || "";

          // Auth: session cookie via credentials: 'same-origin' (the canonical
          // path under PRD-wui-multi-plan v2). The legacy ?token= bearer is
          // still forwarded when present so share-link operators (no cookie)
          // can still create tasks — the server accepts either credential.
          const headers = { "Content-Type": "application/json" };
          if (token) {
            headers["Authorization"] = "Bearer " + token;
          }
          fetch(`/api/v1/tasks?plan_id=${encodeURIComponent(planId)}`, {
            method: "POST",
            credentials: "same-origin",
            headers: headers,
            body: JSON.stringify(payload),
          })
            .then((response) => {
              const statusEl = createTaskForm.querySelector("#create-task-status");
              if (response.ok) {
                createTaskForm.reset();
                if (statusEl) {
                  statusEl.textContent = "Task created!";
                  statusEl.style.color = "var(--ok)";
                }
                setTimeout(() => {
                  if (statusEl) statusEl.textContent = "";
                  // Trigger tasks table refresh via HTMX if available
                  if (window.htmx) {
                    const tasksTable = document.querySelector("#tasks");
                    if (tasksTable) window.htmx.ajax("GET", "/?fragment=tasks", { target: "#tasks", swap: "outerHTML" });
                  }
                }, 1500);
              } else {
                response.text().then((text) => {
                  if (statusEl) {
                    try {
                      const err = JSON.parse(text);
                      statusEl.textContent = err.detail || "Task creation failed";
                    } catch {
                      statusEl.textContent = "Task creation failed";
                    }
                    statusEl.style.color = "var(--danger)";
                  }
                });
              }
            })
            .catch((error) => {
              const statusEl = createTaskForm.querySelector("#create-task-status");
              if (statusEl) {
                statusEl.textContent = `Error: ${error.message}`;
                statusEl.style.color = "var(--danger)";
              }
            });
        });
      }

      // ── Jira Import handlers (Phase 1 WUI) ──
      const jiraRefInput = document.getElementById("jira-ref");
      const jiraPlanIdInput = document.getElementById("jira-plan-id");
      const jiraImportStatus = document.getElementById("jira-import-status");
      const jiraAutonomousBtn = document.getElementById("jira-import-autonomous");
      const jiraWizardBtn = document.getElementById("jira-import-wizard");
      const jiraWizardPanel = document.getElementById("jira-wizard-panel");
      const wizardTaskSummary = document.getElementById("wizard-task-summary");
      const wizardDescription = document.getElementById("wizard-description");
      const wizardCriteria = document.getElementById("wizard-criteria");
      const wizardKeyFiles = document.getElementById("wizard-key-files");
      const wizardTestSteps = document.getElementById("wizard-test-steps");
      const wizardSubmit = document.getElementById("wizard-submit");
      const wizardCancel = document.getElementById("wizard-cancel");
      const wizardStatus = document.getElementById("wizard-status");

      // Pending Jira ref so the wizard knows what to re-import on Send.
      let pendingWizardImport = null;

      function getJiraImportHeaders() {
        const params = new URLSearchParams(window.location.search);
        const token = params.get("token") || "";
        const headers = { "Content-Type": "application/json" };
        if (token) headers["Authorization"] = "Bearer " + token;
        return headers;
      }

      function splitLines(text) {
        if (!text) return [];
        return text
          .split(/\r?\n/)
          .map((s) => s.trim())
          .filter((s) => s);
      }

      function refreshTasksAndPlans() {
        if (window.htmx) {
          const tasksTable = document.querySelector("#tasks");
          if (tasksTable) {
            window.htmx.ajax("GET", "/?fragment=tasks", { target: "#tasks", swap: "outerHTML" });
          }
        }
      }

      function jiraImport(mode, wizardPayload) {
        if (!jiraRefInput) return;
        const jiraRef = (jiraRefInput.value || "").trim();
        if (!jiraRef) {
          if (jiraImportStatus) {
            jiraImportStatus.textContent = "Введи Jira key или URL";
            jiraImportStatus.style.color = "var(--danger)";
          }
          return;
        }
        const planIdOverride = (jiraPlanIdInput.value || "").trim();
        const forceCheckbox = document.getElementById("jira-force");
        const body = {
          jira_ref: jiraRef,
          mode: mode,
        };
        if (planIdOverride) body.plan_id = planIdOverride;
        if (forceCheckbox && forceCheckbox.checked) body.force = true;
        if (wizardPayload) body.wizard = wizardPayload;

        if (jiraImportStatus) {
          jiraImportStatus.textContent = mode === "autonomous" ? "Импортирую…" : "Фетчу Jira…";
          jiraImportStatus.style.color = "var(--muted)";
        }

        fetch("/api/v1/jira/import", {
          method: "POST",
          credentials: "same-origin",
          headers: getJiraImportHeaders(),
          body: JSON.stringify(body),
        })
          .then((response) => response.text().then((text) => ({ ok: response.ok, status: response.status, text })))
          .then(({ ok, status, text }) => {
            let data = null;
            try { data = JSON.parse(text); } catch (e) {}
            if (!ok) {
              const detail = (data && data.detail) || text || `HTTP ${status}`;
              if (jiraImportStatus) {
                jiraImportStatus.textContent = `Ошибка: ${detail.slice(0, 200)}`;
                jiraImportStatus.style.color = "var(--danger)";
              }
              return;
            }
            if (jiraImportStatus) {
              jiraImportStatus.textContent =
                `✓ ${data.jira_key} → plan ${data.plan_id} (${data.task_count} task, kind=${data.kind})`;
              jiraImportStatus.style.color = "var(--ok)";
            }
            refreshTasksAndPlans();
            return data;
          })
          .catch((err) => {
            if (jiraImportStatus) {
              jiraImportStatus.textContent = `Network error: ${err.message}`;
              jiraImportStatus.style.color = "var(--danger)";
            }
          });
      }

      function showWizardAfterFetch() {
        if (!jiraRefInput) return;
        const jiraRef = (jiraRefInput.value || "").trim();
        if (!jiraRef) {
          if (jiraImportStatus) {
            jiraImportStatus.textContent = "Введи Jira key или URL";
            jiraImportStatus.style.color = "var(--danger)";
          }
          return;
        }
        // Just show the wizard form. The import only happens on Send.
        pendingWizardImport = jiraRef;
        if (wizardTaskSummary) wizardTaskSummary.textContent = jiraRef;
        if (jiraWizardPanel) jiraWizardPanel.hidden = false;
        if (jiraImportStatus) {
          jiraImportStatus.textContent = "Заполни форму ниже и нажми Send to agent.";
          jiraImportStatus.style.color = "var(--muted)";
        }
      }

      if (jiraAutonomousBtn) {
        jiraAutonomousBtn.addEventListener("click", () => jiraImport("autonomous", null));
      }
      if (jiraWizardBtn) {
        jiraWizardBtn.addEventListener("click", () => showWizardAfterFetch());
      }
      if (wizardCancel) {
        wizardCancel.addEventListener("click", () => {
          if (jiraWizardPanel) jiraWizardPanel.hidden = true;
          pendingWizardImport = null;
        });
      }
      if (wizardSubmit) {
        wizardSubmit.addEventListener("click", () => {
          if (!pendingWizardImport) return;
          const wizardPayload = {
            description: (wizardDescription.value || "").trim(),
            acceptance_criteria: splitLines(wizardCriteria.value),
            key_files: splitLines(wizardKeyFiles.value),
            test_steps: splitLines(wizardTestSteps.value),
          };
          if (wizardStatus) {
            wizardStatus.textContent = "Отправляю…";
            wizardStatus.style.color = "var(--muted)";
          }
          jiraImport("wizard", wizardPayload);
          if (wizardStatus) {
            setTimeout(() => {
              wizardStatus.textContent = "Готово — see status above";
              wizardStatus.style.color = "var(--ok)";
            }, 800);
          }
        });
      }

      restoreDashboardState();
    })();
  </script>
</body>
</html>
