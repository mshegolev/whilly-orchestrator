<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Link already used — Whilly</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    :root { color-scheme: light dark; }
    body {
      font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      max-width: 28rem; margin: 6rem auto; padding: 0 1.5rem;
      line-height: 1.5;
    }
    h1 { font-size: 1.4rem; margin-bottom: 0.5rem; }
    p.muted { color: #6b7280; margin-top: 0; }
    .cta {
      display: inline-block; margin-top: 1.5rem; padding: 0.6rem 1rem;
      background: #2563eb; color: white; text-decoration: none;
      border-radius: 0.375rem; font-weight: 600;
    }
    .cta:hover { background: #1d4ed8; }
  </style>
</head>
<body>
  <h1>This link has already been used or has expired</h1>
  <p>
    Sign-in links are single-use and valid for 15 minutes. If you need to sign in
    again, request a fresh link below.
  </p>

  <a class="cta" href="/login">Request a new link</a>
</body>
</html>
