# Whilly Orchestrator — demo image (control-plane + worker in one Dockerfile)
#
# Multi-stage сборка единого образа, который умеет работать в двух ролях:
#   1. control-plane (FastAPI / uvicorn)            — `docker run … control-plane`
#   2. whilly-worker (HTTP-клиент к control-plane)  — `docker run … worker`
#
# Используется в docker-compose.demo.yml как два разных сервиса с одним и тем же
# image и разными CMD. Это намеренно: для презентации удобнее показать одну
# сборку, чем поддерживать два почти одинаковых Dockerfile'а.
#
# Build:
#   docker build -f Dockerfile.demo -t whilly-demo:latest .
#
# Run (control-plane):
#   # Подставьте свой DSN; defaults в docker-compose.demo.yml — POSTGRES_USER /
#   # POSTGRES_PASSWORD оба whilly.
#   docker run --rm -p 8000:8000 \
#     -e WHILLY_DATABASE_URL="$WHILLY_DATABASE_URL" \
#     -e WHILLY_WORKER_TOKEN=demo-bearer \
#     -e WHILLY_WORKER_BOOTSTRAP_TOKEN=demo-bootstrap \
#     whilly-demo:latest control-plane
#
# Run (worker):
#   docker run --rm \
#     -e WHILLY_CONTROL_URL=http://host.docker.internal:8000 \
#     -e WHILLY_WORKER_TOKEN=demo-bearer \
#     -e WHILLY_PLAN_ID=demo \
#     whilly-demo:latest worker

ARG PYTHON_VERSION=3.12

# ─── Stage 1: build wheels in a fat image ────────────────────────────────────
FROM python:${PYTHON_VERSION}-slim AS builder

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /build

# Compile-time deps (asyncpg / psycopg-style wheels не нужны, asyncpg идёт
# готовым колесом). Ставим build-essential на всякий случай — если кто-то
# добавит зависимость без prebuilt wheel'а на python:slim.
RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential \
    && rm -rf /var/lib/apt/lists/*

# Сначала ставим только зависимости (по pyproject.toml + минимальный
# whilly/__init__.py чтобы setuptools прочитал __version__). Этот слой
# кэшируется и переиспользуется при изменениях только в исходниках.
COPY pyproject.toml README.md ./
COPY whilly/__init__.py whilly/__init__.py

RUN python -m venv /opt/venv \
    && /opt/venv/bin/pip install --upgrade pip \
    && /opt/venv/bin/pip install '.[all]'

# Полный source. Ставим whilly второй раз без deps и НЕ editable —
# editable .pth указывал бы на /build, который в runtime копируется
# в /opt/whilly (другой путь), и импорты ломались бы. Non-editable
# раскладывает whilly/ внутрь venv'а, и source в runtime больше не нужен.
COPY . .
RUN /opt/venv/bin/pip install --no-deps .

# ─── Stage 2: slim runtime ───────────────────────────────────────────────────
FROM python:${PYTHON_VERSION}-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH=/opt/venv/bin:$PATH \
    WHILLY_LOG_LEVEL=INFO \
    ALEMBIC_CONFIG=/opt/whilly/alembic.ini

# tini — корректный PID 1 для контейнеров (правильно ловит SIGTERM, не зомбирует
# дочерние процессы). curl — для healthcheck. ca-certificates — для HTTPS.
RUN apt-get update \
    && apt-get install -y --no-install-recommends tini curl ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system --gid 1000 whilly \
    && useradd  --system --uid 1000 --gid whilly --create-home --home /home/whilly whilly

COPY --from=builder /opt/venv /opt/venv

# Минимальный набор source-файлов в /opt/whilly:
#   - alembic.ini + alembic_versions для миграций (whilly/adapters/db/migrations
#     уже внутри venv'а, но alembic.ini лежит в корне репо)
#   - examples/ — чтобы plan import видел demo-планы через volume mount
#   - docker/control_plane.py — production-launcher (uvicorn factory mode не
#     умеет передать pool, поэтому открываем pool здесь и зовём create_app(pool))
WORKDIR /opt/whilly
# Используем production-вариант alembic.ini (с абсолютным путём к миграциям
# внутри venv'а), а не корневой — он рассчитан на запуск из source-чекаута,
# которого в этом образе нет.
COPY docker/alembic.prod.ini ./alembic.ini
COPY examples/ ./examples/
# Stub Claude CLI: воркер запускает CLAUDE_BIN на каждой задаче. Stub
# отвечает <promise>COMPLETE</promise> — без расхода реальных токенов.
# Demo-вариант делает sleep 2.5s, чтобы параллельный claim был виден
# на экране (insta-stub успевает обработать обе задачи одним воркером).
COPY tests/fixtures/fake_claude.sh ./tests/fixtures/fake_claude.sh
COPY tests/fixtures/fake_claude_demo.sh ./tests/fixtures/fake_claude_demo.sh
COPY docker/control_plane.py ./docker/control_plane.py
# Universal LLM shim + cgroup-aware resource picker. Drop-in замена
# CLAUDE_BIN для любого OpenAI-compatible провайдера (Groq, OpenRouter,
# Cerebras, Gemini, локальная Ollama). Picker автоматически подбирает
# модель под доступные контейнеру ресурсы (см. docker/llm_resource_picker.py).
COPY docker/llm_shim.py ./docker/llm_shim.py
COPY docker/llm_resource_picker.py ./docker/llm_resource_picker.py
COPY docker/entrypoint.sh /usr/local/bin/whilly-entrypoint
RUN chmod +x /usr/local/bin/whilly-entrypoint \
    /opt/whilly/docker/llm_shim.py \
    /opt/whilly/docker/llm_resource_picker.py \
    && chown -R whilly:whilly /opt/whilly /home/whilly

USER whilly

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/whilly-entrypoint"]
CMD ["control-plane"]
