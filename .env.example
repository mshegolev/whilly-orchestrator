# Whilly Orchestrator — local environment overrides
#
# ─── DEPRECATED ────────────────────────────────────────────────────────────
# Prefer `whilly.example.toml` + keyring-backed secrets. The `.env` loader
# still works for back-compat but emits a warning on every run. Migrate with:
#
#     whilly --config migrate
#
# This template is kept only so existing setups keep building. New projects
# should start from `whilly.example.toml`.
# ───────────────────────────────────────────────────────────────────────────
#
# Copy this file to `.env` and uncomment the variables you want to override.
# `whilly` loads `.env` from the current working directory on startup.
# Real shell environment variables always win — .env is a fallback only.
#
# Secrets (JIRA_API_TOKEN etc.) belong in .env because it is git-ignored.
# Never commit a populated .env.

# ─── Core loop ───────────────────────────────────────────────────────────────
# WHILLY_MAX_ITERATIONS=0              # 0 = unlimited
# WHILLY_MAX_PARALLEL=3                # Concurrent agents (1 = sequential)
# WHILLY_MAX_TASK_RETRIES=5            # Retries before a task is skipped/failed
# WHILLY_DECOMPOSE_EVERY=5             # Re-plan oversized pending tasks every N iterations
# WHILLY_HEARTBEAT_INTERVAL=1          # Dashboard refresh cadence (seconds)
# WHILLY_BUDGET_USD=0                  # 0 = unlimited; warns at 80 %, kills at 100 %
# WHILLY_TIMEOUT=0                     # 0 = unlimited; wall-clock seconds per plan
# WHILLY_MAX_TASKS=0                   # Global cap on task executions (0 = unlimited)

# ─── Agent backend & model ───────────────────────────────────────────────────
# Default agent: opencode + Big Pickle on OpenCode Zen — the free-tier
# anonymous "stealth" model. NO API key, NO `opencode auth login`, NO env
# var setup is required as of 2026-05-02 (zero-key onboarding). During
# Big Pickle's free period collected prompts may be used to improve the
# model — see https://opencode.ai/docs/zen/. Opt out by setting
# WHILLY_MODEL=<other-provider>/<model> below; the override always wins.
#
# Escape hatches (set BOTH the WHILLY_MODEL line and the matching key):
#   • Groq gpt-oss-120b (free tier, ~14k req/day):
#       WHILLY_MODEL=groq/openai/gpt-oss-120b   GROQ_API_KEY=gsk_...
#       (key from https://console.groq.com — never commit a real key)
#   • Anthropic Claude Opus 4.6:
#       WHILLY_MODEL=anthropic/claude-opus-4-6  ANTHROPIC_API_KEY=sk-ant-...
#   • OpenAI gpt-4o-mini:
#       WHILLY_MODEL=openai/gpt-4o-mini         OPENAI_API_KEY=sk-...
WHILLY_CLI=opencode                    # Default agent CLI in worker containers
WHILLY_MODEL=opencode/big-pickle       # Default model (free, anonymous on OpenCode Zen)
# GROQ_API_KEY=                        # Only needed when WHILLY_MODEL=groq/...   (placeholder; never commit a real key)
# WHILLY_AGENT_BACKEND=claude          # "claude" | "opencode" (legacy backend selector)
# WHILLY_AGENT=                        # Legacy alias (kept for back-compat)
# CLAUDE_BIN=claude                    # Path to Claude CLI
# WHILLY_CLAUDE_SAFE=0                 # 1 = prompt before every tool call
# WHILLY_CLAUDE_TIMEOUT=1800           # Claude subprocess timeout (seconds)
# WHILLY_OPENCODE_BIN=opencode         # Path to OpenCode CLI
# WHILLY_OPENCODE_SAFE=0               # 1 = prompt before every tool call
# WHILLY_OPENCODE_SERVER_URL=          # Optional remote OpenCode server

# ─── Workspaces, worktrees, tmux ─────────────────────────────────────────────
# WHILLY_USE_WORKSPACE / WHILLY_WORKTREE were plan-level / per-task git
# worktree toggles in v3. Removed in v4 (TASK-107) — they are now no-ops kept
# only for backward `.env` compatibility (the v4 CLI silently ignores them).
# WHILLY_USE_WORKSPACE=                # removed no-op since v3.3+ (kept for backward script compat)
# WHILLY_WORKTREE=                     # removed no-op since v3.3+ (kept for backward script compat)
# WHILLY_USE_TMUX=0                    # 1 = run each agent in its own tmux session

# ─── Orchestration & decomposition ───────────────────────────────────────────
# WHILLY_ORCHESTRATOR=file             # "file" = key_files collisions, "llm" = ask LLM
# WHILLY_DECOMPOSE_THRESHOLD=          # Task-size threshold that triggers decomposition
# WHILLY_DECISION_GATE=1               # 0 = skip the Decision Gate
# WHILLY_DECISION_GATE_MODEL=          # Override model used by Decision Gate

# ─── Verification / healing / dashboards ─────────────────────────────────────
# WHILLY_VERIFY=1                      # 0 = skip post-task verification
# WHILLY_VOICE=1                       # 0 = silence macOS voice notifications
# WHILLY_HEADLESS=0                    # 1 = JSON stdout, no TUI (auto when non-TTY)
# WHILLY_WEB=0                         # 1 = enable web dashboard (if built)
# WHILLY_MONITOR_INTERVAL_SECONDS=     # Resource monitor cadence
# WHILLY_HEALING_WEBHOOK=              # Self-healing notification webhook
# WHILLY_HEALING_TIMEOUT=              # Self-healing step timeout
# WHILLY_HEALING_VERBOSE=0             # 1 = verbose healing logs
# WHILLY_HEALING_NO_AUTO_INSTALL=0     # 1 = don't auto-install missing tools

# ─── Logging & state ─────────────────────────────────────────────────────────
# WHILLY_LOG_DIR=whilly_logs
# WHILLY_LOG_LEVEL=INFO
# WHILLY_MAX_LOG_DIR_SIZE_GB=          # Rotate/prune when exceeded
# WHILLY_STATE_FILE=.whilly_state.json
# WHILLY_WORKER_ID=                    # Identifier in multi-worker runs
# WHILLY_PLAN=                         # Default plan path (overridden by --tasks)

# ─── Resource limits ─────────────────────────────────────────────────────────
# WHILLY_RESOURCE_CHECK_ENABLED=1
# WHILLY_MAX_CPU_PERCENT=80
# WHILLY_MAX_MEMORY_PERCENT=75
# WHILLY_MIN_FREE_SPACE_GB=5
# WHILLY_PROCESS_TIMEOUT_MINUTES=30
# WHILLY_MAX_PROCESS_MEMORY_MB=        # Optional per-process memory cap

# ─── Merge / PR workflow ─────────────────────────────────────────────────────
# WHILLY_AUTO_MERGE=ask                # "ask" | "never" | "always"
# WHILLY_PR_ON_DONE=0                  # 1 = open PR automatically on completion
# WHILLY_MR_TARGET=upstream main branch
# WHILLY_GH_BIN=gh                     # Path to the GitHub CLI
# WHILLY_PROJECT_URL=                  # GitHub Project URL (for workflow/sync.py)

# ─── GitHub auth (whilly runs `gh` as a subprocess) ──────────────────────────
# Resolution order used by whilly.gh_utils.gh_subprocess_env():
#   1. WHILLY_GH_TOKEN          — whilly-only token; injected as GITHUB_TOKEN
#                                 for the subprocess without touching your shell
#   2. WHILLY_GH_PREFER_KEYRING=1 — strip ambient GITHUB_TOKEN / GH_TOKEN to
#                                 force `gh` to use its keyring auth (macOS Keychain
#                                 / libsecret / Windows Credential Manager)
#   3. otherwise, GITHUB_TOKEN / GH_TOKEN are passed through unchanged —
#      the cross-platform default that just works on Linux / Windows / CI
#
# Linux/Windows/CI users: usually set GITHUB_TOKEN below (or outside .env) and
# leave WHILLY_GH_* unset.
# macOS + `gh auth login` users: set WHILLY_GH_PREFER_KEYRING=1 so whilly ignores
# any stale GITHUB_TOKEN your shell inherited and prefers the keyring token.
# WHILLY_GH_TOKEN=
# WHILLY_GH_PREFER_KEYRING=0

# ─── External integrations: GitHub Issues ────────────────────────────────────
# WHILLY_CLOSE_EXTERNAL_TASKS=1        # 0 = never close external tasks on done
# WHILLY_GITHUB_AUTO_CLOSE=1
# WHILLY_GITHUB_ADD_COMMENTS=1

# ─── External integrations: Jira ─────────────────────────────────────────────
# WHILLY_JIRA_ENABLED=0
# WHILLY_JIRA_SERVER_URL=https://jira.example.com
# WHILLY_JIRA_USERNAME=you@example.com
# WHILLY_JIRA_AUTO_CLOSE=1
# WHILLY_JIRA_ADD_COMMENTS=1
# WHILLY_JIRA_TRANSITION_TO=Done
#
# Fallback names without WHILLY_ prefix also work (used by external_integrations.py):
# JIRA_SERVER_URL=
# JIRA_USERNAME=
# JIRA_API_TOKEN=                      # SECRET — keep only in .env, never commit

# ─── v4.4 distributed deployment: control-plane + worker (M1 split-host) ────
# These knobs are consumed by the new compose files introduced in v4.4
# (`docker-compose.control-plane.yml` and `docker-compose.worker.yml`).
# Full walkthrough lives in `docs/Distributed-Setup.md`.
#
# WHILLY_BIND_HOST controls which host interface the control-plane's port
# 8000 is mapped to in `docker-compose.control-plane.yml`. The default
# `127.0.0.1` (loopback) keeps the API LAN-safe — pick this for laptops,
# Tailscale-only deploys, or any setup where you do NOT want the public
# network to see the API. Set `0.0.0.0` (IPv4 wildcard) or `::` (IPv6
# wildcard) to expose on all interfaces, or a specific interface IP for a
# private LAN bind. Invalid values fail compose at port-mapping parse time
# rather than silently binding to the wildcard.
# WHILLY_BIND_HOST=127.0.0.1            # default; loopback only
# WHILLY_BIND_HOST=0.0.0.0              # expose on all IPv4 interfaces
# WHILLY_BIND_HOST=::                   # expose on all IPv6 interfaces (dual-stack)
# WHILLY_BIND_HOST=10.0.0.5             # bind to a specific LAN IP

# WHILLY_USE_CONNECT_FLOW switches the docker entrypoint's worker role from
# the legacy bash-awk register path to the new `whilly worker connect`
# one-shot bootstrap. Default is OFF so pre-v4.4 single-host demos remain
# byte-equivalent on stderr/stdout. Set to a truthy value (`1`, `true`,
# `yes`, `on`, case-insensitive) to opt in. When enabled, the entrypoint
# delegates registration + keychain persistence + exec to `whilly worker
# connect`, which validates the URL (scheme guard incl. `--insecure` rule)
# before any HTTP call.
# WHILLY_USE_CONNECT_FLOW=0             # default; legacy register-then-exec
# WHILLY_USE_CONNECT_FLOW=1             # opt in to `whilly worker connect`

# ─── v4.4 Tailscale tailnet bootstrap (m1-tailscale-worker-bootstrap) ───────
# Optional: when TAILSCALE_AUTHKEY is set, the worker container joins a
# private Tailscale tailnet at startup (userspace-networking mode — no host
# privileges required) so it can reach a control-plane that lives on the
# laptop's tailnet (e.g. WHILLY_CONTROL_URL=http://m-mac-pro:8000) WITHOUT
# exposing the control-plane to the public internet. Backwards compatible:
# when unset the worker behaves exactly as before (direct HTTP, no tailnet
# involvement).
#
# Mint a tagged auth key at https://login.tailscale.com/admin/settings/keys
#   - Tags:      tag:whilly-worker (required by entrypoint's --advertise-tags)
#   - Ephemeral: yes (recommended — workers come and go)
#   - Reusable:  yes (so multiple workers can share the same key)
#
# SECURITY: TAILSCALE_AUTHKEY is a long-lived credential. NEVER commit a
# real key — `.env` is gitignored, this file ships only the empty
# placeholder. The entrypoint passes the key via env-var substitution and
# does NOT echo it to logs.
TAILSCALE_AUTHKEY=                      # Tailscale tagged auth key (placeholder; never commit a real key)
# TAILSCALE_HOSTNAME=                   # Optional override; default: whilly-worker-<container-hostname>

# ─── v4.0 distributed orchestrator: Postgres ─────────────────────────────────
# v4.0 stores plans, tasks, events, and worker registrations in PostgreSQL 15+.
# `./scripts/db-up.sh` boots `docker-compose.yml` with credentials matching the
# default DSN below. Override here if you point at a non-local Postgres.
WHILLY_DATABASE_URL=postgresql://whilly:whilly@localhost:5432/whilly
# WHILLY_DB_POOL_MIN=2                 # asyncpg pool min_size (TASK-009a)
# WHILLY_DB_POOL_MAX=10                # asyncpg pool max_size (TASK-009a)
#
# Variables consumed by docker-compose.yml when starting the local stack:
# POSTGRES_USER=whilly
# POSTGRES_PASSWORD=whilly
# POSTGRES_DB=whilly
# POSTGRES_PORT=5432
