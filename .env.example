# Whilly Orchestrator — local environment overrides
#
# ─── DEPRECATED ────────────────────────────────────────────────────────────
# Prefer `whilly.example.toml` + keyring-backed secrets. The `.env` loader
# still works for back-compat but emits a warning on every run. Migrate with:
#
#     whilly --config migrate
#
# This template is kept only so existing setups keep building. New projects
# should start from `whilly.example.toml`.
# ───────────────────────────────────────────────────────────────────────────
#
# Copy this file to `.env` and uncomment the variables you want to override.
# `whilly` loads `.env` from the current working directory on startup.
# Real shell environment variables always win — .env is a fallback only.
#
# Secrets (JIRA_API_TOKEN etc.) belong in .env because it is git-ignored.
# Never commit a populated .env.

# ─── Core loop ───────────────────────────────────────────────────────────────
# WHILLY_MAX_ITERATIONS=0              # 0 = unlimited
# WHILLY_MAX_PARALLEL=3                # Concurrent agents (1 = sequential)
# WHILLY_MAX_TASK_RETRIES=5            # Retries before a task is skipped/failed
# WHILLY_DECOMPOSE_EVERY=5             # Re-plan oversized pending tasks every N iterations
# WHILLY_HEARTBEAT_INTERVAL=1          # Dashboard refresh cadence (seconds)
# WHILLY_BUDGET_USD=0                  # 0 = unlimited; warns at 80 %, kills at 100 %
# WHILLY_TIMEOUT=0                     # 0 = unlimited; wall-clock seconds per plan
# WHILLY_MAX_TASKS=0                   # Global cap on task executions (0 = unlimited)

# ─── Agent backend & model ───────────────────────────────────────────────────
# WHILLY_AGENT_BACKEND=claude          # "claude" | "opencode"
# WHILLY_MODEL=claude-opus-4-6[1m]     # Applied to whichever backend is active
# WHILLY_AGENT=                        # Legacy alias (kept for back-compat)
# CLAUDE_BIN=claude                    # Path to Claude CLI
# WHILLY_CLAUDE_SAFE=0                 # 1 = prompt before every tool call
# WHILLY_CLAUDE_TIMEOUT=1800           # Claude subprocess timeout (seconds)
# WHILLY_OPENCODE_BIN=opencode         # Path to OpenCode CLI
# WHILLY_OPENCODE_SAFE=0               # 1 = prompt before every tool call
# WHILLY_OPENCODE_SERVER_URL=          # Optional remote OpenCode server

# ─── Workspaces, worktrees, tmux ─────────────────────────────────────────────
# WHILLY_USE_WORKSPACE=1               # 0 = disable plan-level git worktree
# WHILLY_WORKTREE=0                    # 1 = per-task worktree (needs MAX_PARALLEL>1)
# WHILLY_USE_TMUX=0                    # 1 = run each agent in its own tmux session

# ─── Orchestration & decomposition ───────────────────────────────────────────
# WHILLY_ORCHESTRATOR=file             # "file" = key_files collisions, "llm" = ask LLM
# WHILLY_DECOMPOSE_THRESHOLD=          # Task-size threshold that triggers decomposition
# WHILLY_DECISION_GATE=1               # 0 = skip the Decision Gate
# WHILLY_DECISION_GATE_MODEL=          # Override model used by Decision Gate

# ─── Verification / healing / dashboards ─────────────────────────────────────
# WHILLY_VERIFY=1                      # 0 = skip post-task verification
# WHILLY_VOICE=1                       # 0 = silence macOS voice notifications
# WHILLY_HEADLESS=0                    # 1 = JSON stdout, no TUI (auto when non-TTY)
# WHILLY_WEB=0                         # 1 = enable web dashboard (if built)
# WHILLY_MONITOR_INTERVAL_SECONDS=     # Resource monitor cadence
# WHILLY_HEALING_WEBHOOK=              # Self-healing notification webhook
# WHILLY_HEALING_TIMEOUT=              # Self-healing step timeout
# WHILLY_HEALING_VERBOSE=0             # 1 = verbose healing logs
# WHILLY_HEALING_NO_AUTO_INSTALL=0     # 1 = don't auto-install missing tools

# ─── Logging & state ─────────────────────────────────────────────────────────
# WHILLY_LOG_DIR=whilly_logs
# WHILLY_LOG_LEVEL=INFO
# WHILLY_MAX_LOG_DIR_SIZE_GB=          # Rotate/prune when exceeded
# WHILLY_STATE_FILE=.whilly_state.json
# WHILLY_WORKER_ID=                    # Identifier in multi-worker runs
# WHILLY_PLAN=                         # Default plan path (overridden by --tasks)

# ─── Resource limits ─────────────────────────────────────────────────────────
# WHILLY_RESOURCE_CHECK_ENABLED=1
# WHILLY_MAX_CPU_PERCENT=80
# WHILLY_MAX_MEMORY_PERCENT=75
# WHILLY_MIN_FREE_SPACE_GB=5
# WHILLY_PROCESS_TIMEOUT_MINUTES=30
# WHILLY_MAX_PROCESS_MEMORY_MB=        # Optional per-process memory cap

# ─── Merge / PR workflow ─────────────────────────────────────────────────────
# WHILLY_AUTO_MERGE=ask                # "ask" | "never" | "always"
# WHILLY_PR_ON_DONE=0                  # 1 = open PR automatically on completion
# WHILLY_MR_TARGET=upstream main branch
# WHILLY_GH_BIN=gh                     # Path to the GitHub CLI
# WHILLY_PROJECT_URL=                  # GitHub Project URL (for workflow/sync.py)

# ─── GitHub auth (whilly runs `gh` as a subprocess) ──────────────────────────
# Resolution order used by whilly.gh_utils.gh_subprocess_env():
#   1. WHILLY_GH_TOKEN          — whilly-only token; injected as GITHUB_TOKEN
#                                 for the subprocess without touching your shell
#   2. WHILLY_GH_PREFER_KEYRING=1 — strip ambient GITHUB_TOKEN / GH_TOKEN to
#                                 force `gh` to use its keyring auth (macOS Keychain
#                                 / libsecret / Windows Credential Manager)
#   3. otherwise, GITHUB_TOKEN / GH_TOKEN are passed through unchanged —
#      the cross-platform default that just works on Linux / Windows / CI
#
# Linux/Windows/CI users: usually set GITHUB_TOKEN below (or outside .env) and
# leave WHILLY_GH_* unset.
# macOS + `gh auth login` users: set WHILLY_GH_PREFER_KEYRING=1 so whilly ignores
# any stale GITHUB_TOKEN your shell inherited and prefers the keyring token.
# WHILLY_GH_TOKEN=
# WHILLY_GH_PREFER_KEYRING=0

# ─── External integrations: GitHub Issues ────────────────────────────────────
# WHILLY_CLOSE_EXTERNAL_TASKS=1        # 0 = never close external tasks on done
# WHILLY_GITHUB_AUTO_CLOSE=1
# WHILLY_GITHUB_ADD_COMMENTS=1

# ─── External integrations: Jira ─────────────────────────────────────────────
# WHILLY_JIRA_ENABLED=0
# WHILLY_JIRA_SERVER_URL=https://jira.example.com
# WHILLY_JIRA_USERNAME=you@example.com
# WHILLY_JIRA_AUTO_CLOSE=1
# WHILLY_JIRA_ADD_COMMENTS=1
# WHILLY_JIRA_TRANSITION_TO=Done
#
# Fallback names without WHILLY_ prefix also work (used by external_integrations.py):
# JIRA_SERVER_URL=
# JIRA_USERNAME=
# JIRA_API_TOKEN=                      # SECRET — keep only in .env, never commit
